{% if product.title contains ' - ' %}
    {% assign splitTitle = product.title | split: ' - ' %}
    {% assign productTitleWithoutColor = "" %}
    {% assign indexColor = splitTitle.size | minus: 1 %}
    {% assign currentColor = splitTitle[indexColor] %}
    {% if splitTitle.size == 2%}
      {% assign productTitleWithoutColor = splitTitle[0] %}
    {% else %}
      {% for titleSection in splitTitle  %}
        {% unless forloop.last == true %}
          {% unless forloop.first == true %}
            {% assign productTitleWithoutColor = productTitleWithoutColor | append: " - " %}
          {% endunless %}
        
          {% assign productTitleWithoutColor = productTitleWithoutColor | prepend: titleSection %}
        {% endunless %}
      {% endfor %}
    {% endif %}
  
    {% assign queryByTag = false %}
    {% for tag in product.tags %}
      {% assign firstCharacter = tag | slice: 0 %}
      {% assign lastCharacter = tag | slice: -1,1 %}
      {% if firstCharacter == "*" and lastCharacter == "*" %}
        {% assign queryByTag = tag %}
        {% break %}
      {% else %}
        {% continue %}
      {% endif %}
    {% endfor %}
  {% endif %}
    
  {% assign queryBySale = false %}
  {% if product.price < product.compare_at_price %}
    {% assign queryBySale = true %}
  {% endif %}
  
  <div class="ProductItem {% if use_horizontal %}ProductItem--horizontal{% endif %}" {% if product.title contains ' - ' %}data-is-swatch="true" data-current-color="{{currentColor}}" data-title-without-color="{{productTitleWithoutColor}}" data-query-by-sale="{{ queryBySale }}" {% if queryByTag %}data-query-by-tag="{{queryByTag}}"{%endif%}{% endif %} data-handle="{{product.handle}}" data-gw-product-card-selector>
    {%- if settings.gw_customer_accounts_wishlist_enabled -%}
      <gw-wishlist-button
        class="gw-wishlist-button--product-item"
        product-id="{{ product.id }}"
        variant-id="{{ product.selected_or_first_available_variant.id }}"
        icon-only
      >
        <template name="icon">
          {% render "gw-customer-accounts-icons" with "wishlist_icon" %}
        </template>

        <template name="filled-icon">
          {% render "gw-customer-accounts-icons" with "wishlist_icon_filled" %}
        </template>

        <script type="application/json" data-product-data>
          {
            "handle": "{{ product.handle }}",
            "title": "{{ product.title }}",
            "id": "{{ product.id }}",
            "variantTitle": "{{ product.selected_or_first_available_variant.title }}",
            "price": "{{ product.price | money }}",
            "url": "{{ shop.url }}{{ product.url }}",
            "tags": {{ product.tags | json }},
            "variantId": "{{ product.selected_or_first_available_variant.id }}",
            "featuredImage": {
              "url": "{{ product.featured_image.src | image_url: width: 240 }}",
              "alt": "{{ product.featured_image.alt | strip }}"
            },
            "variants": {
              "nodes": {{ product.variants | json }}
            }
          }
        </script>
      </gw-wishlist-button>
    {%- endif -%}

    <div class="ProductItem__Wrapper">
      {%- comment -%}
      We are using LazySizes to efficiently choose the most appropriate image in the set. However, because internally LazySizes uses srcset, we need to make
      sure that the image sizes we offer is not larger than the max size uploaded by the merchants.
      {%- endcomment -%}
  
      {%- if settings.product_image_size == 'natural' or use_horizontal -%}
        {%- assign use_natural_size = true -%}
      {%- else -%}
        {%- assign use_natural_size = false -%}
      {%- endif -%}
  
      {%- if product.media[1] != blank and use_horizontal != true -%}
        {%- assign has_alternate_image = true -%}
      {%- else -%}
        {%- assign has_alternate_image = false -%}
      {%- endif -%}
  
      <a href="{{ product.url }}" class="ProductItem__ImageWrapper {% if has_alternate_image %}ProductItem__ImageWrapper--withAlternateImage{% endif %}">
        {%- if product.tags contains 'preorder' -%}
          <span class="preorder-badge">PRE-ORDER</span>
        {%- endif -%}
  
        {%- if use_horizontal -%}
          {%- assign max_width = 125 -%}
        {%- else -%}
          {%- assign max_width = product.featured_product.media[1].width -%}
        {%- endif -%}
  
        {%- assign media_aspect_ratio = product.featured_media.aspect_ratio | default: product.featured_product.media[1].aspect_ratio -%}
  
        <div class="AspectRatio AspectRatio--{% if use_natural_size %}withFallback{% else %}natural{% endif %}" style="max-width: {{ max_width }}px; {% if use_natural_size %}padding-bottom: {{ 100.0 | divided_by: media_aspect_ratio }}%;{% endif %} --aspect-ratio: {{ media_aspect_ratio }}">
          {%- comment -%}
          IMPLEMENTATION NOTE: The alternate image (not visible by default) should be the first in the DOM, as the spinner (Image__Loader element) is
          displayed based on the immediately previously shown image.
          {%- endcomment -%}
  
          {%- if has_alternate_image -%}
              {{ product.media[1] | image_url: width: 400 | image_tag: class: "ProductItem__Image ProductItem__Image--alternate", data-media-id: product.media[1].id }}
          {%- endif -%}
  
          {{ product.featured_media | image_url: width: 400 | image_tag: class: "ProductItem__Image", data-media-id: product.featured_media.id }}
  
          <span class="Image__Loader"></span>
        </div>
      </a>
      {% if template contains 'collection' or template contains 'search' or show_mobile_quick_buy %}
        {% unless product.tags contains 'bundle' or product.tags contains 'hide-quickshop' %} 
        <div class="item-add-to-bag desktop-hide">Add to bag</div>
        {% endunless %}
      {% endif %}
  
      {%- if show_labels -%}
        {%- capture product_labels -%}
          {%- for tag in product.tags -%}
            {%- if tag contains '__label' -%}
              <span class="ProductItem__Label Heading Text--subdued">{{ tag | split: '__label:' | last }}</span>
              {%- break -%}
            {%- endif -%}
          {%- endfor -%}
          {%- unless product.tags contains 'waitlist' -%}
            {%- unless product.available -%}
              <span class="ProductItem__Label ProductItem__Label--soldOut Heading Text--subdued">{{ 'product.labels.sold_out' | t }}</span>
            {%- endunless -%}
          {%- endunless -%}
        {%- endcapture -%}
  
        {%- if product_labels != blank -%}
          <div class="ProductItem__LabelList">
            {{ product_labels }}
          </div>
        {%- endif -%}
      {%- endif -%}
  
      {%- if show_product_info -%}
        <div class="ProductItem__Info {% unless use_horizontal %}ProductItem__Info--center{% endunless %}">
          {% unless product.tags contains 'bundle' or product.tags contains 'hide-quickshop' %} 
          <div class="ProductItem__SizeVariants__QuickShop">
            <div class="ProductItem__SizeVariants">
              {% for variant in product.variants %}
                {% assign sizeOption = 1 %}
                {% assign is_preorder = false %}
                {% assign estimated_shipping_date = false %}
                {% for option in product.options %}
                  {% assign downcase_option = option | downcase %}
                  {% if downcase_option == "size" and forloop.index0 != sizeOption %}
                    {% assign sizeOption = forloop.index0 %}
                    {% break %}
                  {% endif%}
                {% endfor %}
                {%- if variant.metafields.preorder.availability -%}
                  {%- assign is_preorder = true -%}
                  {%- assign estimated_shipping_date = variant.metafields.preorder.estimated_shipping_date -%}
                {%- endif -%}
                {% assign variantSizeOption = "option" | append: sizeOption %}
                <a href="#" data-variant-id="{{ variant.id }}" {% if is_preorder %}data-preorder="true" data-preorder-estimated-shipping-date="{{estimated_shipping_date}}"{% endif %} class="add-size-to-cart {% unless variant.available %}sold-out{% endunless %}">
                  {% if is_preorder %}
                    {% render 'icon-preorder' %}
                  {% endif %}
                {{ variant.options[1] }}</a>
              {% endfor %}
            </div>
            <a href="#" class="quickshop_trigger" data-product-handle="{{ product.handle }}">Quick Shop</a>
          </div>
          {% endunless %}
          
          {%- if product.title contains ' - ' -%}
            {% assign splitTitle = product.title | split: ' - ' %}
            {% assign productTitleWithoutColor = "" %}
            {% assign indexColor = splitTitle.size | minus: 1 %}
            {% assign currentColor = splitTitle[indexColor] %}
            {% if splitTitle.size == 2%}
              {% assign productTitleWithoutColor = splitTitle[0] %}
            {% else %}
              {% for titleSection in splitTitle  %}
                {% unless forloop.last == true %}
                  {% unless forloop.first == true %}
                    {% assign productTitleWithoutColor = productTitleWithoutColor | append: " - " %}
                  {% endunless %}
          
                  {% assign productTitleWithoutColor = productTitleWithoutColor | prepend: titleSection %}
                {% endunless %}
              {% endfor %}
            {% endif %}
            {% assign productTitle = productTitleWithoutColor %}
          {%- else -%}          
            {% assign productTitle = product.title %}
          {%- endif -%}
          {%- if show_vendor -%}
          <h3 class="ProductItem__Designer">{{ product.vendor }}</h3>
          {%- endif -%}
  
          <h2 class="ProductItem__Title Heading">
            <a href="{{ product.url }}">{{ productTitle }}</a>
          </h2>
  
          {%- if settings.show_product_rating -%}
            {%- unless use_horizontal -%}
              <div class="ProductItem__Rating Heading Text--subdued u-h7">
                {%- render 'product-rating', product: product -%}
              </div>
            {%- endunless -%}
          {%- endif -%}
  
          {%- if show_color_swatch -%}
            {%- assign color_swatch_list = '' -%}
  
            {%- capture color_swatch -%}
              {%- assign color_label = 'color,colour,couleur,colore,farbe,색,色,färg,farve' | split: ',' -%}
              {%- capture color_name -%}{{ section.id }}-{{ product.id }}{%- endcapture -%}
  
              {%- for option in product.options_with_values -%}
                {%- assign downcased_option = option.name | downcase -%}
  
                {%- if color_label contains downcased_option -%}
                  {%- assign variant_option = 'option' | append: forloop.index -%}
  
                  {%- for value in option.values -%}
                    {%- assign downcased_value = value | downcase -%}
                    {%- capture color_id -%}{{ section.id }}-{{ product.id }}-{{ forloop.index }}{%- endcapture -%}
  
                    {%- for variant in product.variants -%}
                      {%- if variant[variant_option] == value -%}
                        {%- assign variant_for_value = variant -%}
                        {%- break -%}
                      {%- endif -%}
                    {%- endfor -%}
                    {%- if variant_for_value.image -%}
                      <div class="ProductItem__ColorSwatchItem" onclick="window.location.href='{{product.url}}'">
                        {%- capture supported_sizes -%}{%- render 'image-size', sizes: '200,400,600,700,800,900,1000,1200', image: variant_for_value.image -%}{%- endcapture -%}
                        {%- assign variant_image_url = variant_for_value.image | img_url: '1x1' | replace: '_1x1.', '_{width}x.' -%}
                        <input class="ColorSwatch__Radio" type="radio" name="{{ color_name }}" id="{{ color_id }}" value="{{ value | escape }}" {% if option.selected_value == value %}checked="checked"{% endif %} data-variant-url="{{ variant_for_value.url }}{% if variant_for_value.image %}#Image{{ variant_for_value.image.id }}{% endif %}" {% if variant_for_value.image %}data-image-id="{{ variant_for_value.image.id }}" data-image-url="{{ variant_image_url }}" data-image-widths="[{{ supported_sizes }}]" data-image-aspect-ratio="{{ variant_for_value.image.aspect_ratio }}"{% endif %} aria-hidden="true">
                        <label class="ColorSwatch ColorSwatch--small {% if downcased_value == 'white' %}ColorSwatch--white{% endif %}" for="{{ color_id }}" data-color-name-lowercase="{{ value | downcase }}" title="{{ value | escape }}" data-tooltip="{{ value | escape }}"></label>
                      </div>
                    {%- endif -%}
                  {%- endfor -%}
                {%- endif -%}
              {%- endfor -%}
            {%- endcapture -%}
  
            {%- if color_swatch != blank -%}
              {%- capture color_swatch_list -%}
                <div class="ProductItem__ColorSwatchList">
                  {{- color_swatch -}}
                </div>
              {%- endcapture -%}
            {%- endif -%}
          {%- endif -%}
  
          {% for tag in product.tags %}
            {% if tag contains 'Promo_text' %}
              {% assign split_tag = tag | split: ';' %}
              {% assign promo_text_split = split_tag[0] | remove: 'Promo_text:' | remove: 'promo_text:' %}
              {% assign promo_color_split = split_tag[1] | split: ':' %}
              <div class="promo_text" style="order: 999; color: #{{ promo_color_split[1] }}">{{ promo_text_split | replace: '_', ' ' }}</div>
  
              {% break %}
            {% endif %}
          {% endfor %}
  
          {%- if show_price_on_hover == nil -%}
            {%- assign show_price_on_hover = settings.product_show_price_on_hover -%}
          {%- endif -%}
          
          {% comment %}
          {%- if color_swatch_list != blank -%}
            {{- color_swatch_list -}}
          {%- endif -%}
            {% endcomment %}
  
          {%- if product.template_suffix != 'coming-soon' -%}
            <div class="ProductItem__PriceList {% if show_price_on_hover %}ProductItem__PriceList--showOnHover{% endif %} Heading">
              {%- if product.compare_at_price > product.price or product.tags contains 'final-sale' -%}
                {%- if settings.currency_code_enabled -%}
                  <span class="ProductItem__Price Price Price--highlight Text--subdued">{{ product.price | money }}</span>
                  <span class="ProductItem__Price Price Price--compareAt Text--subdued">{{ product.compare_at_price | money }}</span>
                  {% unless product.tags contains 'bundle' %}<span class="ProductMeta__Price Price Price--sale">{% render 'final-sale-tag', product: product %}</span>{% endunless %}
                {%- else -%}
                  <span class="ProductItem__Price Price Price--highlight Text--subdued">{{ product.price | money  }}</span>
                  <span class="ProductItem__Price Price Price--compareAt Text--subdued">{{ product.compare_at_price | money  }}</span>
                  {% unless product.tags contains 'bundle' %}<span class="ProductMeta__Price Price Price--sale">{% render 'final-sale-tag', product: product %}</span>{% endunless %}
                {%- endif -%}
              {%- elsif product.price_varies -%}
                {%- if settings.currency_code_enabled -%}
                  {%- capture formatted_min_price -%}{{ product.price_min | money }}{%- endcapture -%}
                  {%- capture formatted_max_price -%}{{ product.price_max | money }}{%- endcapture -%}
                {%- else -%}
                  {%- capture formatted_min_price -%}{{ product.price_min | money  }}{%- endcapture -%}
                  {%- capture formatted_max_price -%}{{ product.price_max | money  }}{%- endcapture -%}
                {%- endif -%}
  
                <span class="ProductItem__Price Price Text--subdued">{{ 'collection.product.from_price_html' | t: min_price: formatted_min_price, max_price: formatted_max_price }}</span>
              {%- else -%}
                {%- if settings.currency_code_enabled -%}
                  <span class="ProductItem__Price Price">{{ product.price | money }}</span>
                {%- else -%}
                  <span class="ProductItem__Price Price">{{ product.price | money }}</span>
                {%- endif -%}
              {%- endif -%}
              {%- if product.tags contains 'bundle' -%}<span class="product-listing-bundle">BUNDLE</span>{%- endif -%}
              {%- if product.tags contains 'preorder' -%}
                <span class="preorder-badge hide">PRE-ORDER</span>
              {%- endif -%}
            </div>
  
            {%- if product.selected_or_first_available_variant.unit_price_measurement -%}
              <div class="ProductItem__UnitPriceMeasurement">
                <div class="UnitPriceMeasurement Heading Text--subdued">
                  <span class="UnitPriceMeasurement__Price">{{ product.selected_or_first_available_variant.unit_price | money }}</span>
                  <span class="UnitPriceMeasurement__Separator">/ </span>
  
                  <span class="UnitPriceMeasurement__ReferenceValue" {%- if product.selected_or_first_available_variant.unit_price_measurement.reference_value == 1 -%}style="display: none"{% endif %}>
                    {{- product.selected_or_first_available_variant.unit_price_measurement.reference_value -}}
                  </span>
  
                  <span class="UnitPriceMeasurement__ReferenceUnit">{{ product.selected_or_first_available_variant.unit_price_measurement.reference_unit }}</span>
                </div>
              </div>
            {%- endif -%}
          {%- endif -%}
  
          {%- if color_swatch_list != blank -%}
            {{- color_swatch_list -}}
          {%- endif -%}
  
          {% for tag in product.tags %}
            {% if tag contains 'badge::' %}
              {% assign badge = tag | split: 'badge::' | last %}
              {% break %}
            {% endif %}
          {% endfor %}
          {% if badge %}
          <span class="ProductBadge">{{ badge }}</span>
          {% endif %}
        </div>
      {%- endif -%}
    </div>
  
    {%- if use_horizontal -%}
      <a href="{{ product.url }}" class="ProductItem__ViewButton Button Button--secondary hidden-pocket">{{ 'collection.product.view_product' | t }}</a>
    {%- endif -%}
  </div>