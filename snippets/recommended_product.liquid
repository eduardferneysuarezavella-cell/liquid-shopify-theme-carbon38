{% assign rp_product = all_products[settings.cart_recommended_product] %}

<div class="recommended_product-wrapper">
  <div class="recommended_product">
    <div class="rp_image-wrapper">
      {{rp_product.featured_image.src | image_url: width: 200 | image_tag: class: "rp_image" }}
    </div>

    <div class="rp_details">
      {% comment %}<div class="rp_highlight">Add this bestseller</div>{% endcomment %}
      <div class="rp_vendor">{{ rp_product.vendor }}</div>
      <div class="rp_title">{{ rp_product.title }}</div>
      <button
        type="button"
        onclick="addtoCart(this)"
        class="rp_cta"
        data-variant-id="{{rp_product.selected_or_first_available_variant.id | json }}"
      >
        <span>Add to cart</span>
        <span>{{ rp_product.price | money }}</span>
      </button>
    </div>
  </div>
</div>

<script>
  function addtoCart(button) {
    if (!button.getAttribute('disabled')) {
      var formData = {
        items: [],
      };

      button.children[0].innerText = 'ADDING...';

      formData.items.push({
        id: button.dataset.variantId,
        quantity: '1',
        properties: {
          _recommended_product: true,
        },
      });

      fetch(window.Shopify.routes.root + 'cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify(formData),
      })
        .then((response) => {
          return response.json();
        })
        .then((data) => {
          document.documentElement.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
          
          if(typeof item === 'undefined') {
            var item = {
                "Name": data.title,
                "ProductID": data.product_id,
                "ImageURL": data.image,
                "URL": "https://carbon38.com"+data.url,
                "Brand": data.vendor,
                "Price": Shopify.formatMoney(data.price, window.theme.moneyWithCurrencyFormat),
                "Value": data.price / 100,
                "CompareAtPrice": "$0.00"
            }
            if(data.compare_at_price) {
              item["CompareAtPrice"] = Shopify.formatMoney(data.compare_at_price, window.theme.moneyWithCurrencyFormat);
            }
          }
          document.documentElement.dispatchEvent(
            new CustomEvent('product:added', {
              bubbles: true,
              detail: {
                variant: button.dataset.variantId,
                quantity: 1,
                item: item
              },
            })
          );

          button.children[0].innerText = 'ADDED';

          setTimeout(function () {
            button.innerText = 'ADD TO BAG';
          }, 2000);
        })
        .catch((error) => {
          console.error('Error:', error);
        });
    }
  }
</script>

<style>
  .recommended_product-wrapper {
    padding: 0 13px 13px 13px;
  }

  .recommended_product {
    display: flex;
    gap: 10px;
    padding: 10px;
    border: 1px solid #edf4f1;
  }

  .rp_image-wrapper {
    width: 93px;
    overflow: auto;

    img {
      max-width: 100%;
      height: auto;
    }
  }

  .rp_details {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .rp_highlight {
    color: #000;
    font-size: 8px;
    font-style: normal;
    font-weight: 500;
    line-height: normal;
    letter-spacing: 1.28px;
    text-transform: uppercase;

    width: fit-content;
    padding: 5px;
    background: #d1fd7d;
    margin-bottom: 10px;
  }

  .rp_vendor {
    color: #2e2e2e;
    font-size: 11px;
    font-style: normal;
    font-weight: 400;
    line-height: normal;
    letter-spacing: 1.1px;
    text-transform: uppercase;
  }

  .rp_title {
    color: #717171;
    font-size: 9px;
    font-style: normal;
    font-weight: 300;
    line-height: 13px;
    letter-spacing: 0.9px;
    text-transform: uppercase;
    margin-top: 3px;
  }

  .rp_cta {
    width: 100%;
    display: flex;
    justify-content: space-between;
    gap: 10px;

    padding: 8px 10px;
    background: #2e2e2e;
    margin-top: 10px;

    color: #fff;
    font-size: 9px;
    font-style: normal;
    font-weight: 500;
    line-height: 15.04px;
    letter-spacing: 1.76px;
    text-transform: uppercase;
  }
</style>
