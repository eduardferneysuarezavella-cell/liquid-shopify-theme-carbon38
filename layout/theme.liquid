      deferjQuery(function() {
        jQuery(document).ready(function($) {
          
          function renderSwatches() {
            if($('.ProductItem[data-is-swatch="true"]').length) {
              $.each($('.ProductItem[data-is-swatch="true"]'), function(i, product) {
                var productAlreadyLoaded = false;
                var productHandle = $(product).data('handle');
                var queryString = '';
                var queryData = `{`;
                var titleWithoutColor = $(product).data('title-without-color').replace(/\'/g,"").replace(/\"/g,"");
                titleWithoutColor = titleWithoutColor.toLowerCase();
                if(titleWithoutColor in loadedProducts) {
                  productAlreadyLoaded = true;
                } else {
                  queryData += `products(query:"title:'`+titleWithoutColor+` - '*" first:40)  {`
                }
                queryString = titleWithoutColor;
                queryData += `edges {
                      node {
                        id
                        title
                        description
                        handle
                        availableForSale
                        tags
                        totalInventory
                        images(first:2) {
                          edges {
                              node {
                                  url
                                  id
                              }
                          }
                        }
                        compareAtPriceRange {
                          maxVariantPrice {
                            amount
                          }
                          minVariantPrice {
                            amount
                          }
                        }
                        priceRange {
                          maxVariantPrice {
                            amount
                          }
                          minVariantPrice {
                            amount
                          }
                        }
                        variants(first: 10) {
                          edges {
                              node {
                                id
                                availableForSale
                                title
                                quantityAvailable
                              }
                          }
                        }
                      }
                    }
                  } 
                }
                `;
                if(productAlreadyLoaded && queryString in loadedProducts) {
                  $('.ProductItem[data-is-swatch="true"][data-handle="'+productHandle+'"] .ProductItem__ColorSwatchList').html(loadedProducts[queryString]);
                  if(loadedProducts[queryString].includes('toggle-more-less')) {
                    $('.ProductItem[data-is-swatch="true"][data-handle="'+productHandle+'"] .ProductItem__ColorSwatchList').addClass('show-more-less');
                  }
                } else {
                  $.ajax({
                    type : 'POST',
                    url : '/api/2022-07/graphql.json',
                    headers: {
                        'X-Shopify-Storefront-Access-Token': 'e09aedd0f593820ed2af9f6854af7e2b',
                        'Content-Type': 'application/graphql'
                    },
                    data: queryData,
                    success: function(res) {
                      if(res.data.products.edges.length > 0) {
                        var swatches = [];
                        $.each(res.data.products.edges, function(i, color) {
                          /* 
                          if($(product).data('query-by-tag')) {
                            if(color.node.title.includes($(product).data('title-without-color')+' - ')) {
                              swatches.push(color.node);
                            }
                          } else {
                            var swatchHasQueryTag = false;
                            $.each(color.node.tags, function(j, tag) {
                              if(tag.charAt(0) == "*" && tag.charAt(tag.length-1) == "*") {
                                swatchHasQueryTag = true;
                              }
                            });
                            if(!swatchHasQueryTag) {
                              var colorNodeTitle = color.node.title.replace(/\'/g,"").replace(/\"/g,"");
                              if(colorNodeTitle.startsWith(titleWithoutColor+' - ')) {
                                swatches.push(color.node);
                              }
                            }
                          }*/

                          var swatchHasSale = false;
                          if(parseFloat(color.node.priceRange.minVariantPrice.amount) < parseFloat(color.node.compareAtPriceRange.minVariantPrice.amount) || parseFloat(color.node.priceRange.maxVariantPrice.amount) < parseFloat(color.node.compareAtPriceRange.maxVariantPrice.amount) )  {
                            swatchHasSale = true;
                          }
                          if($(product).data('query-by-sale')) {
                            if(swatchHasSale) {
                              if(color.node.title.includes($(product).data('title-without-color')+' - ')) {
                                swatches.push(color.node);
                              }
                            }
                          } else {
                            if(!swatchHasSale) {
                              var colorNodeTitle = color.node.title.replace(/\'/g,"").replace(/\"/g,"");
                              colorNodeTitle = colorNodeTitle.toLowerCase();
                              if(colorNodeTitle.startsWith(titleWithoutColor+' - ')) {
                                swatches.push(color.node);
                              }
                            }
                          }
                        });
            
                        getColorSwatchWithColor(swatches, $(product).data('current-color'), $(product).data('handle'), queryString, swatches.length, 0);
                      }
                    },
                    error: function(status) {
                      console.log(status)
                    }
                  }); 
                } 
              })

              function getColorSwatchWithColor(array, currentColor, productHandle, queryString, totalCount = 0, availableCount = 0) {
                if(array.length) {
                  var color = array[0];
                  var colorName = color.title.split(' - ');
                  colorName = colorName[colorName.length-1];
                  var colorNameLowercase = colorName.toLowerCase();
                  if(window.swatchColorObject[colorNameLowercase]) {
                    var colorSwatchUrl = window.swatchColorObject[colorNameLowercase];
                  } else {
                    var colorSwatchUrl = 'background-image: url(' + window.swatchColorObject.shopifyFilesFolder + window.shopifyHandleize(colorNameLowercase) + '_72x72.png)';
                  }
                  if(!$('.ProductItem[data-is-swatch="true"][data-handle="'+productHandle+'"] .ProductItem__ColorSwatchList').hasClass('graphql-updated')) {
                    $('.ProductItem[data-is-swatch="true"][data-handle="'+productHandle+'"] .ProductItem__ColorSwatchList').empty();
                    $('.ProductItem[data-is-swatch="true"][data-handle="'+productHandle+'"] .ProductItem__ColorSwatchList').addClass('graphql-updated');
                  }

                  var isPreorder = false;
                  var isWaitlist = false;
                  if(color.tags.includes('preorder')) {
                    isPreorder = true;
                  }
                  if(color.tags.includes('waitlist')) {
                    isWaitlist = true;
                  }

                  if(color.availableForSale && !isWaitlist) {
                    availableCount++;
                    var colorSizes = '';
                    color.variants.edges.forEach((size, i) => {
                      colorSizes += size.node.title.toLowerCase().replace(colorNameLowercase, "").replace(' / ', '') + `-`+size.node.id.replace('gid://shopify/ProductVariant/','') + `-` + size.node.availableForSale;
                      if(i < color.variants.edges.length - 1) colorSizes += ",";
                    });

                    $('.ProductItem[data-is-swatch="true"][data-handle="'+productHandle+'"] .ProductItem__ColorSwatchList').append(
                      `<div class="ProductItem__ColorSwatchItem {% if template contains 'collection' or template contains 'search' %}switch-product-images{% endif %}" {% if template contains 'collection' or template contains 'search' %}data-product-handle="`+color.handle+`" data-sizes="`+colorSizes+`" data-primary-image="`+color.images.edges[0].node.url+`" data-secondary-image="`+(color.images.edges[1] ? color.images.edges[1].node.url : "")+`" {% endif %} {% unless template contains 'collection' or template contains 'search' %}onclick="window.location.href='`+window.routes.rootUrlWithoutSlash+`/products/`+color.handle+`'"{% endunless %} style="order: `+(colorName.toLowerCase() == "black" ? 0 : ((10000 - color.totalInventory) < 1  ? 1 : (10000 - color.totalInventory)))+`">
                          <input  class="ColorSwatch__Radio" type="radio" name="color-swatch" id="template--color-swatch-`+productHandle+`-`+color.id.replace('gid://shopify/Product/','')+`" value="`+colorName+`" data-variant-url="`+window.routes.rootUrlWithoutSlash+`/products/`+color.handle+`" aria-hidden="true">
                          <label data-color-name-lowercase="`+colorNameLowercase+`" class="ColorSwatch ColorSwatch--small `+(currentColor == colorName ? 'is-active' : '' )+`" for="template--color-swatch-`+productHandle+`-`+color.id.replace('gid://shopify/Product/','')+`" title="`+colorName+`" data-tooltip="`+colorName+`"></label>
                      </div>
                      `
                    );
                  }
                  array.shift();
                  getColorSwatchWithColor(array, currentColor, productHandle, queryString, totalCount, availableCount);
                } else {
                  if(availableCount > 6) {
                    $('.ProductItem[data-is-swatch="true"][data-handle="'+productHandle+'"] .ProductItem__ColorSwatchList').addClass('show-more-less');
                    $('.ProductItem[data-is-swatch="true"][data-handle="'+productHandle+'"] .ProductItem__ColorSwatchList').append(
                      `<div class="toggle-more-less"><div><span>+ `+(availableCount - 6)+` More</span><span class="hide">- Show less</span></div></div>`
                    );
                  }
                  loadedProducts[queryString] = $('.ProductItem[data-is-swatch="true"][data-handle="'+productHandle+'"] .ProductItem__ColorSwatchList').html();
                }
              }
            }    
          }

          renderSwatches();

          document.addEventListener('theme:loading:end', function() {
            renderSwatches();
          });

          document.addEventListener('product-feed:updated', function(event) {
            setTimeout(function() {
              renderSwatches();
            }, 3500);
          });
        });
      });

      
    </script>

