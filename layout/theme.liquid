      function deferSwiper(method) {
        if (window.Swiper) {
            method();
        } else {
            setTimeout(function() { deferSwiper(method) }, 50);
        }
      }
      function deferYotpo(method) {
        if (window.yotpo) {
            method();
        } else {
            setTimeout(function() { deferYotpo(method) }, 50);
        }
      }
