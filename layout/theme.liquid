      <script>
        document.addEventListener('click', function(e) {
          if(e.target.classList.contains('Collapsible__Button')) {
            e.target.parentElement.classList.toggle('collapse');
          }
      
          if(e.target.parentElement.classList.contains('switch-product-images')) {
            var primaryImage = e.target.parentElement.dataset.primaryImage;
            var secondaryImage = e.target.parentElement.dataset.secondaryImage;
            var productHandle = e.target.parentElement.dataset.productHandle;
            var sizes = e.target.parentElement.dataset.sizes;
            var sizesSplit = sizes.split(',');
            var sizesHTML = ``;
            sizesSplit.forEach(size => {
              var sizeSplit = size.split('-');
              sizesHTML += `<a href="#" data-variant-id="`+sizeSplit[1]+`" class="add-size-to-cart `+(sizeSplit[2] == 'false' ? 'sold-out':'')+`">`+sizeSplit[0]+`</a>`;
            })
      
            var productWrapper = e.target.closest('.ProductItem__Wrapper');
            productWrapper.querySelector('.ProductItem__Image:not(.ProductItem__Image--alternate)').src = primaryImage;
            productWrapper.querySelector('.ProductItem__Image:not(.ProductItem__Image--alternate)').srcset = primaryImage;
            productWrapper.querySelector('.ProductItem__Image.ProductItem__Image--alternate').src = secondaryImage;
            productWrapper.querySelector('.ProductItem__Image.ProductItem__Image--alternate').srcset = secondaryImage;
            productWrapper.querySelector('.ProductItem__SizeVariants').innerHTML = sizesHTML;
            productWrapper.querySelector('.quickshop_trigger').dataset.productHandle = productHandle;
          }
      
          if(e.target.closest('.toggle-more-less') || e.target.classList.contains('toggle-more-less')) {
            e.preventDefault();
            e.target.closest('.show-more-less').classList.toggle('show-all');
          }
      
          if(e.target.classList.contains('Popover__Value') && document.querySelector('.CollectionInner')) {
            document.querySelector('.CollectionToolbar__Item--sort').innerHTML = "<span>{{ 'collection.sorting.title' | t: collection_sort: collection_sort }}</span> " + e.target.innerText;
          }
          
          if(e.target.id == "hideFilters" && document.querySelector('.CollectionInner')) {
            document.querySelector('.CollectionInner').classList.add('hide-sidebar');
            document.querySelector('.CollectionInner').classList.remove('mobile-show-sidebar');
            document.querySelector('.native-collection-wrapper').classList.remove('mobile-overlay');
          }
          if(e.target.id == "showFilters" && document.querySelector('.CollectionInner')) {
            document.querySelector('.CollectionInner').classList.remove('hide-sidebar');
            document.querySelector('.CollectionInner').classList.add('mobile-show-sidebar');
            document.querySelector('.native-collection-wrapper').classList.add('mobile-overlay');
          }
          
          if(e.target.closest('.mobile-show-sidebar') && document.querySelector('.mobile-show-sidebar')) { 
            //console.log("inside sidebar"); 
          } else { 
            if(window.innerWidth <= 1007 && document.querySelector('.CollectionInner')) {
              document.querySelector('.CollectionInner').classList.add('hide-sidebar');
              document.querySelector('.CollectionInner').classList.remove('mobile-show-sidebar');
              document.querySelector('.native-collection-wrapper').classList.remove('mobile-overlay');
            }
          };
          if(e.target.classList.contains("item-add-to-bag")) {
            e.target.closest('.ProductItem').classList.toggle('show-sizes');
          }
    
          if(e.target.classList.contains("clear-filter")) {
            e.target.closest('.Collapsible').querySelectorAll('input:checked').forEach(input => { 
              input.click(); 
            });
          }
      
          if(e.target.classList.contains('add-size-to-cart') && !e.target.classList.contains('sold-out')) {
            e.preventDefault();
            var formData = {
              'items': []
            };
            var itemData = {
              'id': e.target.dataset.variantId,
              'quantity': 1
            }
            if(e.target.dataset.preorder && e.target.dataset.preorder == "true") {
              itemData['properties'] = { 
                '_preorder': true,
                'Estimated shipping date': e.target.dataset.preorderEstimatedShippingDate ? e.target.dataset.preorderEstimatedShippingDate : ''
              }
            }
            formData.items.push(itemData);
            
      
            fetch(window.Shopify.routes.root + 'cart/add.js', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify(formData)
            })
            .then(response => {
              return response.json();
            })
            .then(data => {
                document.documentElement.dispatchEvent(new CustomEvent('cart:refresh', { bubbles: true }));
                // open cart drawer

                if(typeof item === 'undefined') {
                  var itemData = data.items[0];
                  var item = {
                      "Name": itemData.title,
                      "ProductID": itemData.product_id,
                      "ImageURL": itemData.image,
                      "URL": "https://carbon38.com"+itemData.url,
                      "Brand": itemData.vendor,
                      "Price": Shopify.formatMoney(itemData.price, window.theme.moneyWithCurrencyFormat),
                      "Value": itemData.price / 100,
                      "CompareAtPrice": "$0.00"
                  }
                  if(itemData.compare_at_price) {
                    item["CompareAtPrice"] = Shopify.formatMoney(itemData.compare_at_price, window.theme.moneyWithCurrencyFormat);
                  }
                }

                // Dispatch saved cart item event for customer accounts
                const gwCustomerAccounts = document.querySelector('gw-customer-accounts');
                if (gwCustomerAccounts) {
                    const variantId = data.items[0].variant_id;
                    const productId = data.items[0].product_id;
                    if (!variantId || !productId) return;

                    const event = new CustomEvent('gw:saved-items-from-cart', {
                        detail: { 
                            productId: productId,
                            variantId: variantId,
                            target: e.target
                        }
                    });

                    gwCustomerAccounts.dispatchEvent(event);
                }

                document.documentElement.dispatchEvent(
                  new CustomEvent('product:added', {
                    bubbles: true,
                    detail: {
                      variant: e.target.dataset.variantId,
                      quantity: 1,
                      item: item
                    },
                  })
                );
            })
            .catch((error) => {
