  <script type="text/javascript">
    deferDebounce(function() {
      const toteButton = document.getElementById("tote-fitting-room-button");
      const toteText = document.getElementById("tote-fitting-room-text")
      const configToteObserver = { attributes: true, childList: true, subtree: true };
      const targetNode = toteButton.form.id;

      const fetchIsVariantInStock = async (data) => {
          var result = await fetch(
              `https://api.bookwithtote.com/api/widget/variant-check/${data.selected_variant_id}`,
              {
                  method: "POST",
                  headers: { "Content-Type": "application/json" },
                  body: JSON.stringify(data),
              }
          ).then((x) => x.json());
          if(result.isInStock) {
            if(toteButton.disabled) {
              toteButton.disabled = false;
            }
            if(toteButton.style.display == 'none') {
              toteButton.style.display = 'initial';
              toteText.style.display = 'initial';
            }
          } else if(!result.isInStock) {
            if(!toteButton.disabled) {
              toteButton.disabled = true;
            }
            if(toteButton.style.display !== "none") {
              toteButton.style.display="none";
               toteText.style.display = 'none';
            }
          }
      };
      const debouncedFetchIsVariantInStockVersion = debounce(
          fetchIsVariantInStock
      );
      const callback = (mutationList, observer) => {
          if(mutationList.length === 1 && mutationList[0].target.id === "tote-fitting-room-button") {
            return;
          }
        
          let selectedVariantId = null;
          const searchParams = new URLSearchParams(window.location.search);
          const searchParamsVariant = searchParams.get("variant");
          if(searchParamsVariant) {
            selectedVariantId = searchParamsVariant
          }
    
          if(!selectedVariantId) {
            return;
          }
          const data = {
              selected_variant_id:
                  selectedVariantId,
              shopify_id: 57860915389,
          };
          
          debouncedFetchIsVariantInStockVersion(data);
          
      };
      const observer = new MutationObserver(callback);
      observer.observe(targetNode, configToteObserver);
  
       let selectedVariantId = null;
      const searchParams = new URLSearchParams(window.location.search);
      const searchParamsVariant = searchParams.get("variant");
      if(searchParamsVariant) {
        selectedVariantId = searchParamsVariant
