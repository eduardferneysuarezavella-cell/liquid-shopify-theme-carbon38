    function moveYotpoToBottom() {
      const checkYotpoMainLoaded = setInterval(checkYotpoMain, 50);
  
        function checkYotpoMain() {
          if(document.querySelector('#yotpo-reviews-main-widget') && document.querySelector('#yotpo-reviews-main-widget').parentElement.dataset.yotpoElementLoaded == 'true') {
            var yotpoWidgetInstance = document.querySelector('#yotpo-reviews-main-widget');
  
            if(yotpoWidgetInstance.querySelector('.yotpo-empty-state') || yotpoWidgetInstance.querySelector('#yotpo-reviews-container')) {
              if(yotpoWidgetInstance.querySelector('.yotpo-empty-state')) {
                var section = yotpoWidgetInstance.closest('section');
                section.parentNode.appendChild(section);
              } else {
              }
              stopYotpoMainLoaded();
            }
          }
        }
  
        function stopYotpoMainLoaded() {
          clearInterval(checkYotpoMainLoaded);
        }
    }
    window.addEventListener('DOMContentLoaded', () => {
      deferYotpo(function() {
        Yotpo.ready(function() {
          moveYotpoToBottom();
        });
      })
      
      document.addEventListener('visibilitychange', async function () { 
        moveYotpoToBottom();
      }); 
    });
  </script>

