{%- layout none -%}
{
    "item_count": {{ cart.item_count | json }},
    "items": [
        {%- for item in cart.items -%}
            {
                "id": {{ item.id | json }},
                "tags": {{ item.product.tags | json }},
                "product_id": {{ item.product_id | json }},
                "final_line_price": {{ item.final_line_price | json }},
                "product_type": {{ item.product_type | json }},
                "properties": {
                    {%- if item.properties._is_gwp -%}"_is_gwp": true{%- endif -%}
                }
            }{%- unless forloop.last -%},{%- endunless -%}
        {%- endfor -%}
    ]
}