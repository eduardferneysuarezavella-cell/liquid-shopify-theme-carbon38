{{ 'faq-menu.css' | asset_url | stylesheet_tag }}

<ul class="faq-menu">
  {% for block in section.blocks %}
    <li class="faq-menu__item">
      <a class="faq-menu__link" href="#faq-section-{{ block.settings.question_title | handleize }}">
        <h2 class="faq-menu__title">{{ block.settings.question_title }}</h2>
      </a>
    </li>
  {% endfor %}
</ul>

<script>
  const firstTitle = document.querySelector('.faq-menu__item a');
  if (firstTitle) {
    firstTitle.classList.add('active');
  }

  document.querySelectorAll('.faq-menu__item a').forEach((link) => {
    link.addEventListener('click', function (event) {
      document.querySelectorAll('.faq-menu__item a').forEach((item) => {
        item.classList.remove('active');
      });
      this.classList.add('active');
    });
  });
</script>

{% schema %}
{
  "name": "FAQ Menu",
  "tag": "section",
  "class": "shopify-section--faq-menu",
  "settings": [],
  "blocks": [
    {
      "type": "faq-menu-item",
      "name": "FAQ Menu",
      "settings": [
        {
          "type": "text",
          "id": "question_title",
          "label": "Question Title"
        }
      ]
    }
  ]
}
{% endschema %}
