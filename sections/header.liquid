{%- assign use_transparent_header = false -%}

{%- if template == 'index' and section.settings.enable_transparent_header -%}
  {%- assign use_transparent_header = true -%}
{%- endif -%}

{%- if template.name == 'collection' and section.settings.enable_transparent_header_collection and collection.image and collection.all_products_count > 0 and collection.template_suffix != 'no-image' -%}
  {%- assign use_transparent_header = true -%}
{%- endif -%}

<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-cart-notification.css' | asset_url }}" media="print" onload="this.media='all'">

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if section.settings.menu_type_desktop == 'mega' -%}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}


<style>
  header-drawer {
    justify-self: start;
    margin-left: 0;

    .header__icon--menu {
      position: relative;
      top: -11px;
    }
  }

  {%- if section.settings.sticky_header_type == 'reduce-logo-size' -%}
    .scrolled-past-header .header__heading-logo-wrapper {
      width: 75%;
    }
  {%- endif -%}

  {%- if section.settings.menu_type_desktop != "drawer" -%}
    @media screen and (min-width: 1140px) {
      header-drawer {
        display: none;
      }
    }
  {%- endif -%}

  .menu-drawer-container {
    display: flex;
  }

  /* Prevent body scroll when menu drawer is open */
  body.menu-drawer-open {
    overflow: hidden;
    position: fixed;
    width: 100%;
    height: 100%;
    touch-action: none; /* Prevent touch scrolling */
  }

  /* Fallback for older browsers */
  @supports not (overscroll-behavior: contain) {
    body.menu-drawer-open {
      overflow: hidden;
      -webkit-overflow-scrolling: auto;
    }
  }

  /* Ensure menu drawer content is scrollable */
  .menu-drawer {
    overflow-y: auto;
    max-height: 100vh;
    max-height: 100dvh; /* Dynamic viewport height for modern browsers */
    -webkit-overflow-scrolling: touch; /* iOS smooth scrolling */
    overscroll-behavior: contain; /* Prevent scroll chaining */
  }

  .menu-drawer__inner-container {
    min-height: 100vh;
    min-height: 100dvh; /* Dynamic viewport height for modern browsers */
    display: flex;
    flex-direction: column;
    /* Let parent .menu-drawer handle scrolling */
  }

  /* Improve mobile touch scrolling */
  @media (max-width: 749px) {
    .menu-drawer {
      -webkit-overflow-scrolling: touch;
      overflow-y: scroll;
      scrollbar-width: none; /* Firefox */
      -ms-overflow-style: none; /* IE/Edge */
    }
    
    .menu-drawer::-webkit-scrollbar {
      display: none; /* Chrome/Safari */
    }
    
    .menu-drawer__inner-container {
      /* Remove overflow from inner container - let parent handle it */
      overflow-y: visible;
      min-height: auto;
    }
    
    .menu-drawer__navigation-container {
      /* Remove individual scrolling - let parent menu-drawer handle it */
      overflow-y: visible;
    }
  }

  .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .list-menu--inline {
    display: inline-flex;
  }

  .list-menu__item {
    display: flex;
    align-items: center;
    font-size: 13px;
    line-height: 15px;
    letter-spacing: 1.2px;
    font-weight: 400;
  }

  .list-menu__item--link {
    text-decoration: none;
  }

  .menu-drawer__mobile-image {
    margin-right: 15px;
  }

  /* CSS-based logo and currency selector visibility control */
  /* When menu drawer is open, hide logo and show mobile currency selector */
  body:has(.menu-drawer-container[open]) .header__heading-logo-wrapper {
    display: none !important;
  }
  
  body:has(.menu-drawer-container[open]) .mobile-menu-currency-selector {
    display: flex !important;
    align-items: center;
    justify-content: center;
  }
  
  /* When menu drawer is closed, show logo and hide mobile currency selector */
  body:not(:has(.menu-drawer-container[open])) .mobile-menu-currency-selector {
    display: none !important;
  }

  /* Plus/Minus icon toggle using CSS */
  /* Default state: show plus, hide minus */
  .menu-drawer details summary .icon-plus {
    display: inline-block !important;
  }
  
  .menu-drawer details summary .icon-minus {
    display: none !important;
  }
  
  /* When details is open: hide plus, show minus */
  .menu-drawer details[open] summary .icon-plus {
    display: none !important;
  }
  
  .menu-drawer details[open] summary .icon-minus {
    display: inline-block !important;
  }

  /* Sticky-subnav hiding when currency selector is open */
  /* Hide sticky-subnav when mobile currency dropdown is open */
  body:has(.mobile-menu-currency-selector .disclosure__list-wrapper:not([hidden])) .section-sticky-subnav {
    position: relative !important;
    top: -2px !important;
  }
  
  body:has(.mobile-menu-currency-selector .disclosure__list-wrapper:not([hidden])) sticky-subnav {
    display: none !important;
    visibility: hidden !important;
  }

  /* Side by Side Images Styles */
  .side-by-side-images {
    width: 100%;
    padding: 0;
    flex-shrink: 0; /* Prevent shrinking in flex container */
  }

  .side-by-side-images__container {
    display: flex;
    gap: 6px;
    max-width: 100%;
    padding: 0 10px;
  }

  .side-by-side-images__item {
    flex: 1;
    position: relative;
    margin-bottom: 40px;
  }

  .menu-drawer__menu.has-submenu.list-menu.parent-menu > li:nth-child(1) {
    position: relative;
  }
  
  .menu-drawer__menu.has-submenu.list-menu.parent-menu > li:nth-child(1)::before {
    content: "";
    position: absolute;
    top: 0;
    left: 10px;
    right: 10px;
    height: 1px;
    background-color: #DEDEDE;
  }

  .side-by-side-images__link {
    display: block;
    text-decoration: none;
    color: inherit;
    width: 100%;
    height: 100%;
    margin-bottom: 40px;
  }

  .side-by-side-images__image-wrapper {
    position: relative;
    width: 100%;
    overflow: hidden;
    margin-bottom: 40px;
  }

  .side-by-side-images__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
    border-radius: 5px;
    min-height: 171px;
  }

  .side-by-side-images__content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 2;

  }

  .side-by-side-images__text {
    font-size: 13px;
    letter-spacing: 8%;
    color: #FFFFFF;
    line-height: 100%;
    font-weight: 700;
    font-family: "Euclid";
    width: 121px;
  }

  .menu-drawer__menu-item.parent-links {
    font-weight: 400;
    font-size: 16px;
  }

  .currency-symbol {
    width: 21px;
    height: 21px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    border: 1px solid #000000;
  }

  .mobile-only {
    display: flex;
    gap: 6px;
    align-items: center;
    font-size: 11.5px;
    font-family: 'Euclid';
    font-weight: 400;
  }

  .desktop-only {
    display: none;
  }

  .icon-plus, .icon-minus {
    position: absolute;
    right: 15px;
  }

  /* Wishlist icon styling */
  .header__icon--wishlist {
    display: flex !important;
    align-items: center;
    justify-content: center;
  }

  .header__icon--wishlist .icon-heart {
    width: 20px;
    height: 18px;
    stroke: currentColor;
    fill: none;
  }

  /* Ensure wishlist icons are visible on correct breakpoints */
  .header__icon--wishlist.large-up-hide {
    display: flex !important; /* Mobile wishlist icon */
  }

  .header__icon--wishlist.small-hide.medium-hide {
    display: flex !important; /* Desktop wishlist icon */
  }

  @media (min-width: 1140px) {
    .header__icon--wishlist.large-up-hide {
      display: none !important; /* Hide mobile wishlist on desktop */
    }
    
    .header__icon--wishlist.small-hide.medium-hide {
      display: flex !important; /* Show desktop wishlist */
    }
  }

  @media (max-width: 1139px) {
    .header__icon--wishlist.small-hide.medium-hide {
      display: none !important; /* Hide desktop wishlist on mobile */
    }
    
    .header__icon--wishlist.large-up-hide {
      display: flex !important; /* Show mobile wishlist */
    }
  }

  @media (min-width: 1140px) {
    .side-by-side-images__text {
      font-size: 20px;
    }
    .mobile-only {
      display: none;
    }

    .desktop-only {
      display: flex;
    }
  }

  @media (max-width: 749px) {
    .header__heading-logo-wrapper img {
      max-width: {{ settings.mobile_logo_max_width }}px;
    }
    
    /* Minimal mobile browser toolbar fix */
    .side-by-side-images {
      /* Minimal bottom padding to account for browser toolbars */
      padding-bottom: max(env(safe-area-inset-bottom, 20px), 33px);
      margin-bottom: 13px;
      /* Ensure proper positioning within viewport */
      min-height: auto;
      /* Use dynamic viewport units that account for browser UI */
      max-height: calc(100dvh - 83px);
    }
    
    .side-by-side-images__container {
      /* Minimal bottom margin for toolbar clearance */
      margin-bottom: 18px;
      /* Minimal padding */
      padding-bottom: 13px;
    }
    
    .side-by-side-images__link {
      /* Reduce bottom margin */
      margin-bottom: 28px;
    }
    
    /* Specific fixes for different browser toolbar positions */
    
    /* When browser toolbar is at bottom */
    @supports (height: 100dvh) {
      .side-by-side-images {
        /* Use dynamic viewport height that responds to browser UI */
        max-height: calc(100dvh - 63px);
        /* Minimal padding for bottom toolbar */
        padding-bottom: max(env(safe-area-inset-bottom, 20px), 43px);
      }
    }
    
    /* Additional spacing for very small screens */
    @media (max-height: 700px) {
      .side-by-side-images {
        padding-bottom: max(env(safe-area-inset-bottom, 20px), 48px);
        margin-bottom: 18px;
      }
    }
    
    /* Ensure menu drawer also accounts for browser toolbars */
    .menu-drawer {
      /* Use dynamic viewport that accounts for browser UI */
      max-height: 100dvh;
      min-height: 100dvh;
      /* Minimal bottom padding to prevent content cut-off */
      padding-bottom: max(env(safe-area-inset-bottom, 20px), 28px);
    }
    
    .menu-drawer__inner-container {
      /* Ensure inner container has proper spacing */
      min-height: calc(100dvh - 28px);
      /* Minimal bottom padding for toolbar clearance */
      padding-bottom: max(env(safe-area-inset-bottom, 20px), 18px);
    }
  }

  .menu-drawer__mobile-image-wrapper img {
    border-radius: 3px;
    width: 50px;
    height: 50px;
    object-fit: cover;
  }

  .menu-drawer__mobile-image {
    margin-right: 15px;
  }
</style>

{%- style -%}
  .header {
    padding: 25px 17px;
  }

  .section-header {
    position: sticky; /* This is for fixing a Safari z-index issue. PR #2147 */
  }

  /* .header__heading-logo-wrapper {
    display: none;
  } */

  @media screen and (min-width: 1140px) {
    .header {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
    /* .header__heading-logo-wrapper {
      display: inline-block;
    } */
  }
{%- endstyle -%}

<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

