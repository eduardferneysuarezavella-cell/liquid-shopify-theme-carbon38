{% comment %} Customer Accounts Main Template {% endcomment %}
<template id="gw-customer-accounts-template">
  {%- # theme-check-disable RemoteAsset -%}
  <gw-css-loader file="main.css?v={{ customer_accounts_version }}" defer></gw-css-loader>
  {%- # theme-check-disable RemoteAsset -%}

  <link rel="stylesheet" href="{{ 'gw-customer-accounts-custom.css' | asset_url }}">

  {{ main_data }}
  {{ main_css }}

  <sl-drawer
    class="drawer-placement-start"
    placement="{{ section.settings.drawer_placement }}"
    label="Drawer"
    main-drawer
    hidden
  >
    <div class="gw-header gw-customer-accounts-drawer__header" slot="label" data-main-drawer-label>
      {% liquid
        assign label = 'gw_customer_accounts.tabs.dashboard.label_fallback' | t

        if customer.first_name
          assign label = 'gw_customer_accounts.tabs.dashboard.label' | t: first_name: customer.first_name
        endif

        echo label
      %}
    </div>

    <button slot="header-actions" class="gw-empty-button" data-main-drawer-close aria-label="Close my account drawer">
      {% render 'gw-customer-accounts-icons' with 'close' %}
    </button>

    {% unless customer.has_account %}
      <sl-animation duration="250" iterations="1" fill="both" gw-sign-in-block-animation>
        <gw-customer-accounts-sign-in type="{{ section.settings.sign_in_type }}">
          {% if section.settings.sign_in_type == 'passwordless' %}
            <div class="gw-sign-in" data-sign-in-block>
              <h3 class="gw-header gw-header--large" data-sign-in-block-heading></h3>

              <form class="gw-sign-in__form" data-sign-in-form>
                <sl-input name="email" type="email" label="Email" required data-email-input></sl-input>
                <div class="gw-error-message" aria-live="polite" hidden data-email-error></div>
                <button type="submit" class="gw-button gw-button--solid">
                  Sign in
                  <span class="gw-loader-container" hidden data-loader>
                    <span class="gw-loader"></span>
                  </span>
                </button>
              </form>

              <span class="gw-small-text">
                {{ 'gw_customer_accounts.sign_in_block.help_text_html' | t }}
              </span>
            </div>
            <div class="gw-verify-code" data-verify-code-block hidden>
              <h3 class="gw-header gw-header--large">
                {{ 'gw_customer_accounts.verify_code_block.title' | t }}
              </h3>
              <div>
                <p>{{ 'gw_customer_accounts.verify_code_block.enter_the_code' | t }}</p>
                <p class="gw-body--strong" data-code-sent-to></p>
              </div>

              <div class="input-code-group">
                <input type="number" name="code" class="code-input" required autocomplete="off">
                <input type="number" name="code" class="code-input" required autocomplete="off">
                <input type="number" name="code" class="code-input" required autocomplete="off">
                <input type="number" name="code" class="code-input" required autocomplete="off">
              </div>

              <div class="gw-verify-code__actions">
                <span
                  class="gw-loader-container gw-loader-container--large gw-loader-container--block"
                  hidden
                  data-loader
                >
                  <span class="gw-loader gw-loader--white"></span>
                </span>

                <div class="gw-error-message" aria-live="polite" hidden data-verify-error>
                  {{ 'gw_customer_accounts.verify_code_block.incorrect_code' | t }}
                </div>

                <a
                  href="/account/login?my-account=off&return_url=%2F?my-account-open"
                  class="gw-button gw-button--text"
                  data-alt-sign-in-link
                  data-ignore-account-link
                >
                  {{ 'gw_customer_accounts.verify_code_block.having_trouble' | t }}
                </a>

                <button class="gw-button gw-button--text" data-send-another-code>
                  {{ 'gw_customer_accounts.verify_code_block.send_another_code' | t }}
                </button>

                <button class="gw-button gw-button--text" data-try-another-email>
                  {{ 'gw_customer_accounts.verify_code_block.try_another_email' | t }}
                </button>
              </div>
            </div>
          {% else %}
            <div class="gw-sign-in" data-sign-in-block>
              {% comment %}
                Customer login form
              {% endcomment %}
              {%- form 'customer_login', novalidate: 'novalidate', class: 'gw-sign-in__form', data-sign-in-form: '' -%}
                <h3 class="gw-header gw-header--large" style="margin-bottom: 8px;">
                  {{ 'gw_customer_accounts.sign_in_block.dashboard_title' | t }}
                </h3>
                <div class="gw-error-message" data-login-error-message style="margin: -8px 0 8px 0;"></div>
                <sl-input name="customer[email]" type="email" label="Email" required data-email-input></sl-input>
                <sl-input
                  name="customer[password]"
                  type="password"
                  label="Password"
                  required
                  data-password-input
                ></sl-input>
                {%- if form.errors -%}
                  <div class="gw-error-message" hidden aria-live="polite">
                    {{ form.errors | default_errors }}
                  </div>
                {%- else -%}
                  <div class="gw-error-message" aria-live="polite" hidden data-email-error></div>
                {%- endif -%}

                <input type="hidden" name="return_url" value="/?my-account-open">
                <input type="hidden" name="return_to" value="/?my-account-open">

                {% if settings.gw_customer_accounts_marketing_optin_enabled %}
                  <div class="gw-marketing-optin" style="margin-top: 15px;">
                    <sl-checkbox
                      name="accepts_marketing"
                      value="true"
                      checked
                    >
                      <span class="gw-body">
                        {{ settings.gw_customer_accounts_marketing_optin_text }}
                      </span>
                    </sl-checkbox>
                  </div>
                {% endif %}

                <button type="submit" class="gw-button gw-button--solid">
                  Sign in
                  <span class="gw-loader-container" hidden data-loader>
                    <span class="gw-loader"></span>
                  </span>
                </button>

                <button type="button" class="gw-empty-button gw-button--text" data-create-account-link>
                  Create an account
                </button>
                <button type="button" class="gw-empty-button gw-button--text" data-forgot-password-link>
                  Forgot your password?
                </button>
              {%- endform -%}

              {% comment %}
                Customer registration form
              {% endcomment %}
              {%- form 'create_customer',
                novalidate: 'novalidate',
                class: 'gw-sign-in__form',
                data-registeration-form: '',
                hidden: ''
              -%}
                <h3 class="gw-header gw-header--large" style="margin-bottom: 8px;">
                  {{ 'gw_customer_accounts.sign_in_block.create_account_title' | t }}
                </h3>
                <div class="gw-error-message" data-create-account-error-message></div>
                <sl-input name="customer[first_name]" type="text" label="First name" required></sl-input>
                <sl-input name="customer[last_name]" type="text" label="Last name" required></sl-input>
                <sl-input name="customer[email]" type="email" label="Email" required></sl-input>
                <sl-input name="customer[password]" type="password" label="Password" required></sl-input>

                {%- if form.errors -%}
                  <div class="gw-error-message" aria-live="polite" hidden>
                    {{ form.errors | default_errors }}
                  </div>
                {%- else -%}
                  <div class="gw-error-message" aria-live="polite" hidden data-email-error></div>
                {%- endif -%}

                <input type="hidden" name="return_url" value="/?my-account-open">
                <input type="hidden" name="return_to" value="/?my-account-open">

                <button type="submit" class="gw-button gw-button--solid">
                  Create an account
                  <span class="gw-loader-container" hidden data-loader>
                    <span class="gw-loader"></span>
                  </span>
                </button>

                <button type="button" class="gw-empty-button gw-button--text" data-sign-in-link>Sign in</button>
                <button type="button" class="gw-empty-button gw-button--text" data-forgot-password-link>
                  Forgot your password?
                </button>
              {%- endform -%}

              {% comment %}
                Customer password recovery form
              {% endcomment %}
              {%- form 'recover_customer_password',
                id: 'recover_customer',
                class: 'gw-sign-in__form',
                data-forgot-password-form: '',
                hidden: ''
              -%}
                <h3 class="gw-header gw-header--large">{{ 'gw_customer_accounts.sign_in_block.forgot_password_title' | t }}</h3>
                <p class="gw-body gw-body--small" style="margin-bottom: 8px;" data-forgot-password-subtext>{{ 'gw_customer_accounts.sign_in_block.forgot_password_subtext' | t }}</p>
                <div class="gw-error-message" data-forgot-password-error-message style="margin: 0px 0 8px 0;"></div>
                <sl-input name="email" type="email" label="Email" required data-email-input></sl-input>
                {%- if form.errors -%}
                  <div class="gw-error-message" aria-live="polite" hidden>
                    {{ form.errors | default_errors }}
                  </div>
                {%- else -%}
                  <div class="gw-error-message" aria-live="polite" hidden data-email-error></div>
                {%- endif -%}

                <input type="hidden" name="return_url" value="/?my-account-open">
                <input type="hidden" name="return_to" value="/?my-account-open">

                <button type="submit" class="gw-button gw-button--solid">
                  Submit
                  <span class="gw-loader-container" hidden data-loader>
                    <span class="gw-loader"></span>
                  </span>
                </button>

                <button type="button" class="gw-empty-button gw-button--text" data-create-account-link>
                  Create an account
                </button>
                <button type="button" class="gw-empty-button gw-button--text" data-sign-in-link>Sign in</button>
              {% endform %}
            </div>
          {% endif %}
        </gw-customer-accounts-sign-in>
      </sl-animation>
    {% endunless %}

    <sl-tab-group
      placement="bottom"
      {% if customer.has_account %}
        has-customer
      {% endif %}
      {% if section.settings.sign_in_type == 'password' %}
        sign-in-type-password
      {% endif %}
    >
      <sl-tab-panel name="dashboard">
        {% render 'gw-customer-accounts-tabs', tab: 'dashboard', section: section %}
      </sl-tab-panel>

      <sl-tab-panel
        name="orders"
        {% unless customer.has_account %}
          style="display:none;"
        {% endunless %}
      >
        {% render 'gw-customer-accounts-tabs', tab: 'orders' %}
      </sl-tab-panel>

      <sl-tab-panel
        name="profile"
        {% unless customer.has_account %}
          style="display:none;"
        {% endunless %}
      >
        {% render 'gw-customer-accounts-tabs', tab: 'profile' %}
      </sl-tab-panel>

      <sl-tab class="gw-button-text gw-unstyled-link" slot="nav" panel="dashboard">
        {{ 'gw_customer_accounts.tabs.dashboard.menu_label' | t }}
      </sl-tab>
      <sl-tab class="gw-button-text gw-unstyled-link" slot="nav" panel="orders">
        {{ 'gw_customer_accounts.tabs.orders.menu_label' | t }}
      </sl-tab>
      <sl-tab class="gw-button-text gw-unstyled-link" slot="nav" panel="profile">
        {{ 'gw_customer_accounts.tabs.profile.menu_label' | t }}
      </sl-tab>
    </sl-tab-group>
  </sl-drawer>

  <div class="gw-notifications" data-notifications>
    <sl-alert variant="success" duration="3000" data-notification-alert>
      <span data-notification-message class="gw-body"></span>
    </sl-alert>
  </div>
</template>

