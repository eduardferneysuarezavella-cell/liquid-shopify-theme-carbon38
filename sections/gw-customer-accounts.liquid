        --color-solid-button-text: {{ section.settings.solid_button_text_color }};
        --color-solid-button-background: {{ section.settings.solid_button_background_color }};
        --color-solid-button-border: {{ section.settings.solid_button_border_color }};
        --color-solid-button-hover-text: {{ section.settings.solid_button_hover_text_color }};
        --color-solid-button-hover-background: {{ section.settings.solid_button_hover_background_color }};
        --color-solid-button-hover-border: {{ section.settings.solid_button_hover_border_color }};

        --color-stroke-button-text: {{ section.settings.stroke_button_text_color }};
        --color-stroke-button-background: {{ section.settings.stroke_button_background_color }};
        --color-stroke-button-border: {{ section.settings.stroke_button_border_color }};
        --color-stroke-button-hover-text: {{ section.settings.stroke_button_hover_text_color }};
        --color-stroke-button-hover-background: {{ section.settings.stroke_button_hover_background_color }};
        --color-stroke-button-hover-border: {{ section.settings.stroke_button_hover_border_color }};

        --color-disabled-button-text: {{ section.settings.disabled_button_text_color }};
        --color-disabled-button-background: {{ section.settings.disabled_button_background_color }};

        --text-case-button: {{ section.settings.text_case }};
        --font-weight-button: {{ section.settings.font_weight }};
        --corner-radius-button: {{ section.settings.corner_radius }}px;
