<style>
  {% liquid
    # Import fonts from Font Picker if available
    assign header_font_family = section.settings.header_font_family
    assign body_font_family = section.settings.body_font_family
    assign button_font_family = section.settings.button_font_family
    assign form_font_family = section.settings.form_font_family

    assign header_font_face = section.settings.header_font
    assign body_font_face = section.settings.body_font
    assign button_font_face = section.settings.button_font
    assign form_font_face = section.settings.form_font

    if header_font_family == blank
      assign header_font_family = header_font_face.family

      for variant in header_font_face.variants
        if variant.weight == section.settings.header_font_weight
          echo variant | font_face
        endif
      endfor
    endif

    if body_font_family == blank
      assign body_font_family = body_font_face.family

      for variant in body_font_face.variants
        if variant.weight == section.settings.body_font_weight
          echo body_font_face | font_face
        endif
      endfor
    endif

    if button_font_family == blank
      assign button_font_family = button_font_face.family

      for variant in button_font_face.variants
        if variant.weight == section.settings.button_font_weight
          echo button_font_face | font_face
        endif
      endfor
    endif

    if form_font_family == blank
      assign form_font_family = form_font_face.family

      for variant in form_font_face.variants
        if variant.weight == section.settings.form_elements_font_weight
          echo form_font_face | font_face
        endif
      endfor
    endif
  %}
</style>

