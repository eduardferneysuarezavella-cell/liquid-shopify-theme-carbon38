{%- if product.title contains ' - ' -%}
  {% assign splitTitle = product.title | split: ' - ' %}
  {% assign productTitleWithoutColor = "" %}
  {% assign indexColor = splitTitle.size | minus: 1 %}
  {% assign currentColor = splitTitle[indexColor] %}
  {% if splitTitle.size == 2%}
    {% assign productTitleWithoutColor = splitTitle[0] %}
  {% else %}
    {% for titleSection in splitTitle  %}
      {% unless forloop.last == true %}
        {% unless forloop.first == true %}
          {% assign productTitleWithoutColor = productTitleWithoutColor | append: " - " %}
        {% endunless %}

        {% assign productTitleWithoutColor = productTitleWithoutColor | prepend: titleSection %}
      {% endunless %}
    {% endfor %}
  {% endif %}
  {% assign productTitle = productTitleWithoutColor %}
{%- else -%}          
  {% assign productTitle = product.title %}
{%- endif -%}

{% liquid 
  assign linked_styles = 0
  assign hasStyles = false
  if template.name == 'product'
    for component in product.metafields.style.linked_products.value
      if component.id != product.id 
      assign linked_styles = linked_styles | plus: 1
      endif
    endfor 

    if linked_styles >= 1 and product.metafields.style.current != blank
      assign hasStyles = true
      assign productTitle = productTitle | remove: product.metafields.style.current
      assign firstLetterInTitle = productTitle | slice: 0
      if firstLetterInTitle == " "
        assign productTitle = productTitle | remove_first: " "
      endif
    endif
  endif
%}

