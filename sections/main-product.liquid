{% if product.vendor == "CARBON38" and product.title contains ' - ' %}
  {%- liquid
    assign splitTitle = product.title | split: ' - '
    assign productTitleWithoutColor = ""
    assign indexColor = splitTitle.size | minus: 1
    assign currentColor = splitTitle[indexColor] | downcase
  -%}

<script async>
  if(document.querySelector('.shop-by-color-family')) {
    deferjQuery(function() {      

      var slickScript = document.createElement('script');
        slickScript.src = "//cdn.jsdelivr.net/npm/slick-carousel@1.8.1/slick/slick.min.js";

        document.head.appendChild(slickScript);

        function deferSlick(method) {
            if (window.jQuery('body').slick) {
                method();
            } else {
                setTimeout(function() { deferSlick(method) }, 50);
            }
        }

      jQuery(document).ready(function($) {
        console.log("current color: {{ currentColor }}")
        $.ajax({
          type : 'POST',
          url : '/api/2022-07/graphql.json',
          headers: {
              'X-Shopify-Storefront-Access-Token': 'e09aedd0f593820ed2af9f6854af7e2b',
              'Content-Type': 'application/graphql'
          },
          data: `{
            products(query:"title:'* - {{ currentColor }}' AND vendor:'CARBON38'" first:12 sortKey:BEST_SELLING) {
              edges {
                node {
                  id
                  title
                  description
                  handle
                  availableForSale
                  onlineStoreUrl
                  tags
                  totalInventory
                  images(first:1) {
                    edges {
                        node {
                            url
                            id
                            height
                            width
                        }
                    }
                  }
                  compareAtPriceRange {
                    maxVariantPrice {
                      amount
                    }
                    minVariantPrice {
                      amount
                    }
                  }
                  priceRange {
                    maxVariantPrice {
                      amount
                    }
                    minVariantPrice {
                      amount
                    }
                  }
                }
              }
            } 
          }
          `,
          success: function(res) {
            if(res.data.products.edges.length > 0) {
              var swatches = [];
              $.each(res.data.products.edges, function(i, color) {
                if (color.node.onlineStoreUrl == null) {
                  return;
                }

                var colorNodeTitle = color.node.title.replace(/\'/g,"").replace(/\"/g,"");
                colorNodeTitle = colorNodeTitle.toLowerCase();

                var colorName = color.node.title.split(' - ');
                var productTitle = colorName[0];
                colorName = colorName[colorName.length-1];
                var colorNameLowercase = colorName.toLowerCase();
                var imageWidth = 225 * (color.node.images.edges[0].node.width / color.node.images.edges[0].node.height)
                if(colorNodeTitle.endsWith(' - {{ currentColor }}')) {
                  $('.complete-the-look.shop-by-color-family .ctl-slider-loading').append(`
                    <div class="ctl-product" onclick="this.querySelector('.ctl-open-qv').click()">
                      <div class="ctl-image">
                        <img src="`+color.node.images.edges[0].node.url+`" width="`+imageWidth+`" height="225" loading="lazy" alt="`+productTitle+`">
                        <a href="#" class="ctl-open-qv quickshop_trigger" data-product-handle="`+color.node.handle+`">Quick Shop</a>
                      </div>
                      <div class="ctl-vendor">CARBON38</div>
                      <h4>`+productTitle+`</h4>    
                      <div class="ctl-price">`+Shopify.formatMoney(color.node.priceRange.minVariantPrice.amount*100, window.theme.moneyWithCurrencyFormat)+`</div>
                    </div>  
                  `);
                }
              });

              $('.complete-the-look.shop-by-color-family .ctl-slider-loading').addClass('ctl-slider');
              deferSlick(function() {
                $('.ctl-slider.ctl-slider-loading').slick({
                  slidesToShow: 3,
                  infinite: false,
                  prevArrow: `<button class="slick-prev slick-arrow" aria-label="Previous" type="button" aria-disabled="true" style=""><svg width="10" height="9" viewBox="0 0 10 9" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M3.90967 7.34019L0.999216 4.42974" stroke="#717171" stroke-linecap="square"/>
                      <path d="M1 4.43045L3.91045 1.52" stroke="#717171" stroke-linecap="square"/>
                      <path d="M1.20093 4.44408H9.19393H1.20093Z" fill="white"/>
                      <path d="M1.20093 4.44408H9.19393" stroke="#717171"/>
                      </svg>              
                      </button>`,
                  nextArrow: `<button class="slick-next slick-arrow" aria-label="Next" type="button" style="" aria-disabled="false"><svg width="10" height="9" viewBox="0 0 10 9" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M6.09033 1.54799L9.00078 4.45844" stroke="#717171" stroke-linecap="square"/>
                      <path d="M9 4.45773L6.08955 7.36818" stroke="#717171" stroke-linecap="square"/>
                      <path d="M8.79907 4.44411L0.806072 4.44411L8.79907 4.44411Z" fill="white"/>
                      <path d="M8.79907 4.44411L0.806072 4.44411" stroke="#717171"/>
                      </svg></button>`,
                  responsive: [
                      {
                          breakpoint: 1024,
                          settings: {
                            slidesToShow: 4,
                          }
                      },
                      {
                          breakpoint: 749,
                          settings: {
                            slidesToShow: 3,
                          }
                      },
                      {
                          breakpoint: 480,
                          settings: {
                            slidesToShow: 2,
                          }
                      }
                  ]
                });
              });
              $('.complete-the-look.shop-by-color-family').addClass('loaded');
            }
          },
          error: function(status) {
            console.log(status)
          }
        });  // end ajax
      }); // end jQuery
    }); // end deferjQuery
  }
</script>
