        <div class="sticky-dropdown-trigger">
          <span></span>
          <svg width="11" height="7" viewBox="0 0 11 7" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 1.5L5.75736 5.74264L1.51472 1.5" stroke="#2E2E2E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </div>
      {% endif %}
    {% endunless %}
    <div class="sticky-size sticky-dropdown-wrapper">
      {%- for option in product.options_with_values -%}
        {%- assign downcase_option = option.name | downcase -%}
        {%- assign variant_option = 'option' | append: forloop.index -%}
        {% if downcase_option == "size" %}
        {% assign currentSelection = option.selected_value %}
        <ul class="{% if downcase_option == "size" %}SizeSwatchList{% endif %} sticky-dropdown sticky-size">
          {%- for value in option.values -%}
            {% assign show_size = false %}
            {% assign is_preorder = false %}
            {% assign estimated_shipping_date = false %}
            {%- for variant in product.variants -%}
              {%- if variant[variant_option] == value -%}
                {%- if variant.metafields.preorder.availability -%}
                  {%- assign is_preorder = true -%}
                  {%- assign estimated_shipping_date = variant.metafields.preorder.estimated_shipping_date -%}
                {%- endif -%}
                {%- if variant.image -%}
                  {% assign show_size = true %}
                  {%- break -%}
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            {% if show_size == true %}
              <li class="HorizontalList__Item" {% if is_preorder %}data-preorder="true" data-preorder-estimated-shipping-date="{{estimated_shipping_date}}"{% endif %}>
                {% if is_preorder %}
                  {% render 'icon-preorder' %}
                {% endif %}
                <svg class="SizeSwatch__Strikethrough">
                    <line x1='0' y1='100%' x2='100%' y2='0'stroke="currentColor" />
                </svg>
                <input id="option-{{ section.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}" class="SizeSwatch__Radio" type="radio" name="option-{{ forloop.parentloop.index0 }}" value="{{ value | escape }}" {% if value == option.selected_value %}checked="checked"{% endif %} data-option-position="{{ option.position }}">
                <label for="option-{{ section.id }}-{{ forloop.parentloop.index0 }}-{{ forloop.index0 }}" class="SizeSwatch">{{ value }}</label>
              </li>
            {% endif %}
          {%- endfor -%}
        </ul>
        <div class="sticky-dropdown-trigger">
          <span>Size</span>
          <svg width="11" height="7" viewBox="0 0 11 7" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M10 1.5L5.75736 5.74264L1.51472 1.5" stroke="#2E2E2E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        {%- endif -%}
      {%- endfor -%}

    </div>
    <div class="sticky-quantity">
      <div class="QuantitySelector QuantitySelector--large">
        <button type="button" class="QuantitySelector__Button Link Link--secondary" data-action="decrease-quantity">{% render 'icon' with 'minus' %}</button>
        <input type="text" class="QuantitySelector__CurrentQuantity" pattern="[0-9]*" name="quantity" value="1" aria-label="{{ 'product.form.quantity' | t }}">
        <button type="button" class="QuantitySelector__Button Link Link--secondary" data-action="increase-quantity">{% render 'icon' with 'plus' %}</button>
      </div>
      {%- if product.tags contains 'QTY_LIMITER' -%}
        {%- for tag in product.tags -%}
          {%- if tag contains 'MAX_QTY::' -%}
            <div class="ProductForm__Quantity-Limiter">
            Limit {{ tag | remove: 'MAX_QTY::' | times: 1 }}
            </div>
            {% break %}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>
    <div class="sticky-atc">
      <button type="submit" data-use-primary-button="{% if use_primary_button %}true{% else %}false{% endif %}" class="ProductForm__AddToCart Button {% if product.selected_or_first_available_variant.available and use_primary_button %}Button--primary{% else %}Button--secondary{% endif %} Button--full" {% if has_multiple_sizes and available_sizes > 1 %}disabled="disabled"{% endif %}>
        {%- if product.options.size > 1 and has_multiple_sizes and available_sizes > 1 -%}
          {% if product.available %}{{ 'product.form.atc_no_selection' | t }}{% else %}{{- 'product.form.out_of_stock' | t -}}{% endif %}                        
        {%- else -%}
          {%- if product.selected_or_first_available_variant.available -%}
            <span>{% if product.tags contains 'preorder' and product.variants.size == 1 and product.selected_or_first_available_variant.metafields.preorder.availability %}{{ 'product.form.pre_order' | t }}{% else %}{{ 'product.form.add_to_cart' | t }}{% endif %}</span>
          {%- else -%}
            {{- 'product.form.sold_out' | t -}}
          {%- endif -%}
        {%- endif -%}
      </button>
      <div class="disabled-overlay"></div>
    </div>
  </div>
</div>

<script defer>
  // When the user scrolls the page, execute myFunction
  window.onscroll = function() {toggleStickyATC()};

  // Get the header
  var stickyATCContainer = document.querySelector(".pdp-sticky-atc");

  // Get the offset position of the navbar
  var stickyATC = stickyATCContainer.offsetTop;

  // Add the sticky class to the header when you reach its scroll position. Remove "sticky" when you leave the scroll position
  function toggleStickyATC() {
    const sectionStickySubnav = document.querySelector('.section-sticky-subnav');
    if (sectionStickySubnav) {
      document.documentElement.style.setProperty('--section-sticky-subnav-height', sectionStickySubnav.offsetHeight + 'px');
    }

    var buyButton = document.getElementById('ProductForm__Quantity-Buy');
    var buyButtonScreenPosition = buyButton.getBoundingClientRect();
    if (buyButtonScreenPosition.top < 0) {
      stickyATCContainer.classList.add("sticky");
    } else {
      stickyATCContainer.classList.remove("sticky");
    }
  }

  deferjQuery(function() {      
    jQuery(document).ready(function($) {
      $('.sticky-dropdown-wrapper').on('click', function(e) {
        e.stopPropagation();
        $(this).toggleClass('active');
      });

      $('body').on('click', function() {
        $('.sticky-dropdown-wrapper.active').removeClass('active');
      })

      $('.ProductForm__Quantity-Buy .QuantitySelector__CurrentQuantity').on('change', function() {
        $('.sticky-quantity input').val($(this).val());
      });

      $('body').on('click', '.sticky-atc .ProductForm__AddToCart:not([disabled])', function(e) {
        e.preventDefault();
        document.querySelector('section.Product .Product__Info .Container > form.ProductForm .ProductForm__AddToCart').click();
      });

      $('body').on('click', '.sticky-atc', function(e) {
        e.preventDefault();
        if(window.innerWidth <= 1006 && $(this).find('.ProductForm__AddToCart[disabled]').length) {
          const y = document.querySelector('.ProductForm__Variants').getBoundingClientRect().top + window.scrollY - 100;
          window.scroll({
            top: y,
            behavior: 'smooth'
          });
        }
      });

      $('.sticky-quantity .QuantitySelector__Button').on('click', function(e) {
        e.preventDefault();
        document.querySelector('section.Product .Product__Info .Container > form.ProductForm .QuantitySelector button[data-action="'+$(this).data('action')+'"]').click();
      })

      $('.sticky-quantity .QuantitySelector__CurrentQuantity').on('change', function(e) {
        $('section.Product .Product__Info .Container > form.ProductForm .QuantitySelector .QuantitySelector__CurrentQuantity').val($(this).val());
        $('section.Product .Product__Info .Container > form.ProductForm .QuantitySelector .QuantitySelector__CurrentQuantity').trigger('change');
      });
    })
  })
</script>

