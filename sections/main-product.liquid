<script>
  // To power the recently viewed products section, we save the ID of the product inside the local storage
  (() => {
    let items = JSON.parse(localStorage.getItem('recentlyViewedProducts') || '[]');

    // We check if the current product already exists, and if it does not, we add it at the start
    if (!items.includes({{ product.id }})) {
      items.unshift({{ product.id }});
    }

    // Then, we save the current product into the local storage, by keeping only the 8 most recent
    try {
      localStorage.setItem('recentlyViewedProducts', JSON.stringify(items.slice(0, 8)));
    } catch (error) {
      // Do nothing, this may happen in Safari in incognito mode
    }
  })();

  document.addEventListener('DOMContentLoaded', function() {    
    const productHandle = '{{ product.handle }}';
    const recentlyViewedProducts = JSON.parse(localStorage.getItem('recentlyViewedProductsHandle')) || [];

    if (!recentlyViewedProducts.includes(productHandle)) {
      recentlyViewedProducts.push(productHandle);
    }

    if (recentlyViewedProducts.length > 8) {
      recentlyViewedProducts.shift();
    }

    localStorage.setItem('recentlyViewedProductsHandle', JSON.stringify(recentlyViewedProducts));
  });

  // Another script to save the recently viewed products with more information like id, image, price and title for the cart drawer
  {% if product.available %}
  (() => {
    let items = JSON.parse(localStorage.getItem('recentlyViewedProductsData') || '[]');
    let product = {
      id: {{ product.id }},
      featured_image: {{ product.featured_image | json }},
      price: {{ product.selected_or_first_available_variant.price }},
      title: {{ product.title | json }},
      handle: {{ product.handle | json }},
      tags: {{ product.tags | json }}
    };

    if (!items.find(item => item.id === product.id)) {
      items.unshift(product);
    }

    try {
      localStorage.setItem('recentlyViewedProductsData', JSON.stringify(items.slice(0, 12)));
    } catch (error) {}
  })();
  {% endif %}
</script>

{%- if settings.gw_customer_accounts_wishlist_enabled -%}
  {% capture wishlist_button %}
    <gw-wishlist-button
      class="gw-wishlist-button--product-item"
      product-id="{{ product.id }}"
      variant-id="{{ product.selected_or_first_available_variant.id }}"
      icon-only
    >
      <template name="icon">
        {% render "gw-customer-accounts-icons" with "wishlist_icon" %}
      </template>

      <template name="filled-icon">
        {% render "gw-customer-accounts-icons" with "wishlist_icon_filled" %}
      </template>

      <script type="application/json" data-product-data>
        {
          "handle": "{{ product.handle }}",
          "title": "{{ product.title }}",
          "id": "{{ product.id }}",
          "variantTitle": "{{ product.selected_or_first_available_variant.title }}",
          "price": "{{ product.price | money }}",
          "url": "{{ shop.url }}{{ product.url }}",
          "tags": {{ product.tags | json }},
          "variantId": "{{ product.selected_or_first_available_variant.id }}",
          "featuredImage": {
            "url": "{{ product.featured_image.src | image_url: width: 240 }}",
            "alt": "{{ product.featured_image.alt | strip }}"
          },
          "variants": {
            "nodes": {{ product.variants | json }}
          }
        }
      </script>
    </gw-wishlist-button>
  {% endcapture %}
{%- endif -%}

<section class="Product Product--large" data-section-id="{{ section.id }}" data-section-type="product" data-section-settings='{{ section_settings }}'>
  <div class="Product__Wrapper">

    {%- comment -%}
    --------------------------------------------------------------------------------------------------------------------
    PRODUCT GALLERY
    --------------------------------------------------------------------------------------------------------------------
    {%- endcomment -%}

    {%- assign initial_media_id = product.featured_media.id -%}
    {%- assign initial_media_index = 0 -%}
    {%- assign media_count = 0 -%}

    {%- capture slideshow_media -%}
      {%- for media in product.media -%}
        {%- if product.selected_variant and media.id == product.selected_variant.featured_media.id -%}
          {%- assign initial_media_index = media_count -%}
          {%- assign initial_media_id = media.id -%}
        {%- endif -%}

        {%- capture supported_sizes -%}{%- render 'image-size', sizes: '200,400,600,700,800,900,1000,1200,1400,1600', image: media -%}{%- endcapture -%}

        {%- case media.media_type -%}
          {%- when 'image' -%}
            {%- liquid
              assign splitTitle = product.title | split: ' - '
              assign productTitleWithoutColor = ""
              assign indexColor = splitTitle.size | minus: 1
              assign currentColor = splitTitle[indexColor] | downcase
            -%}
            <div data-product-type="{{product.type}}" id="Media{{ media.id }}" tabindex="0" class="Product__SlideItem Product__SlideItem--image Carousel__Cell {% if initial_media_id == media.id %}is-selected{% endif %}" data-media-type="image" data-media-id="{{ media.id }}" data-media-position="{{ media.position }}" data-image-media-position="{% increment image_position %}" data-color="{{ currentColor }}"  data-visibility="show">
              {% if product.media.size == 1  and wishlist_button %}{{ wishlist_button }}{% endif %}
              <div class="AspectRatio AspectRatio--withFallback" style="padding-bottom: {{ 100.0 | divided_by: media.aspect_ratio }}%; --aspect-ratio: {{ media.aspect_ratio }};">
                {{ media | image_url: width: 1000 | image_tag: class: "Image--fadeIn" }}
                <span class="Image__Loader"></span>
              </div>
            </div>

          {%- when 'external_video' -%}
            <div data-product-type="{{product.type}}" id="Media{{ media.id }}" tabindex="-1" class="Product__SlideItem Product__SlideItem--video Carousel__Cell {% if initial_media_id == media.id %}is-selected{% endif %}" data-media-type="external_video" data-media-id="{{ media.id }}" data-media-position="{{ media.position }}" data-video-host="{{ media.host | escape }}" data-video-id="{{ media.external_id | escape }}">
              {% if product.media.size == 1  and wishlist_button %}{{ wishlist_button }}{% endif %}
              <div class="Image--lazyLoad Image--fadeIn" data-expand="-100">
                <div class="VideoWrapper">
                  {{- media | external_video_tag: image_size: '1024x' -}}
                </div>
              </div>
            </div>

          {%- when 'video' -%}
            <div data-product-type="{{product.type}}" id="Media{{ media.id }}" tabindex="-1" class="Product__SlideItem Product__SlideItem--video Carousel__Cell {% if initial_media_id == media.id %}is-selected{% endif %}" data-media-type="video" data-media-id="{{ media.id }}" data-media-position="{{ media.position }}">
              {% if product.media.size == 1  and wishlist_button %}{{ wishlist_button }}{% endif %}
              <div class="Image--lazyLoad Image--fadeIn" data-expand="-100">
                <div class="VideoWrapper VideoWrapper--native" style="padding-bottom: {{ 100.0 | divided_by: media.aspect_ratio }}%">
                  {{- media | video_tag: image_size: '1024x', controls: true -}}
                </div>
              </div>
            </div>

          {%- when 'model' -%}
            <div data-product-type="{{product.type}}" id="Media{{ media.id }}" tabindex="-1" class="Product__SlideItem Product__SlideItem--model Carousel__Cell {% if initial_media_id == media.id %}is-selected{% endif %}" data-media-type="model" data-media-id="{{ media.id }}" data-media-position="{{ media.position }}">
              {% if product.media.size == 1  and wishlist_button %}{{ wishlist_button }}{% endif %}
              <div class="Image--lazyLoad Image--fadeIn" data-expand="-100">
                <div class="ModelWrapper">
                  {{- media | model_viewer_tag: image_size: '1024x', reveal: 'interaction', toggleable: true -}}
                </div>
              </div>
            </div>
        {%- endcase -%}

        {%- assign media_count = media_count | plus: 1 -%}
      {%- endfor -%}
    {%- endcapture -%}

    {%- if product.media.size > 0 -%}
      <div class="Product__Gallery {% if product.media.size == 1 %}just-one-image{% endif %} Product__Gallery--stack {% if section.settings.show_thumbnails and media_count > 1 %}Product__Gallery--withThumbnails{% else %}Product__Gallery--withDots{% endif %}">
        <span id="ProductGallery" class="Anchor"></span>
        {%- capture slideshow_nav -%}
          {%- if media_count > 1 -%}
            {%- if section.settings.show_thumbnails -%}
              <div class="Product__SlideshowNav Product__SlideshowNav--thumbnails">
                <div class="Product__SlideshowNavScroller">
                  {%- for media in product.media -%}
                    {%- capture nav_item_badge -%}
                      {%- case media.media_type -%}
                        {%- when 'model' -%}
                          <span class="Product__SlideshowNavBadge">{% render 'icon', icon: 'media-model-badge' %}</span>

                        {%- when 'video' or 'external_video' -%}
                          <span class="Product__SlideshowNavBadge">{% render 'icon', icon: 'media-video-badge' %}</span>
                      {%- endcase -%}
                    {%- endcapture -%}

                    <a href="#Media{{ media.id }}" data-offset="-25" data-change-slide data-focus-on-click data-media-id="{{ media.id }}" class="Product__SlideshowNavImage AspectRatio {% if forloop.first %}is-selected{% endif %}" style="--aspect-ratio: {{ media.preview_image.aspect_ratio }}">
                      {{ media | image_url: width: 160 | image_tag }}
                      {{- nav_item_badge -}}
                    </a>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          {%- endif -%}
        {%- endcapture -%}

        {{- slideshow_nav -}}

        {%- capture flickity_options -%}
        {
          "prevNextButtons": false,
          "pageDots": false,
          "adaptiveHeight": false,
          "watchCSS": true,
          "autoPlay": true,
          "cellAlign": "left",
          "dragThreshold": 8,
          "initialIndex": {{ initial_media_index }},
          "arrowShape": {"x0": 20, "x1": 60, "y1": 40, "x2": 60, "y2": 35, "x3": 25}
        }
        {%- endcapture -%}

        <div class="Product__Slideshow Carousel" data-autoplay-interval="{{  section.settings.autoplay | default: 3000 }}" data-flickity-config='{{ flickity_options }}'>
          {%- if wishlist_button and product.media.size > 1 -%}{{ wishlist_button }}{%- endif -%}
          {{ slideshow_media }}
        </div>

        {%- comment -%}Add the "view in your space" button, which allows to show the product in customer's environment (if the device supports it){%- endcomment -%}
        {%- assign first_3d_model = product.media | where: 'media_type', 'model' | first -%}

        {%- if first_3d_model -%}
          <button class="Product__ViewInSpace Button Button--full" data-shopify-xr data-shopify-model3d-id="{{ first_3d_model.id }}" data-shopify-model3d-default-id="{{ first_3d_model.id }}" data-shopify-title="{{ product.title | escape }}" data-shopify-xr-hidden>
            {%- render 'icon', icon: 'media-view-in-space' -%} {{- 'product.general.view_in_space' | t -}}
          </button>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="Product__InfoWrapper">
      <div class="Product__Info {% if media_count == 0 %}Product__Info--noGallery{% endif %}">
        <div class="Container">
          {%- assign has_ouputted_variant_selector = false -%}

          {%- form 'product', product, class: 'ProductForm' -%}
            {% if settings.enable_gift and settings.gift_wrap_product.id == product.id %}
              <input type="hidden" name="properties[_is_gift_wrap]" value="true">
            {% endif %}
            {%- render 'product-data', product: product -%}

            {%- for block in section.blocks -%}
              {%- case block.type -%}
                {%- when '@app' -%}
                  {%- render block -%}

                {%- when 'product_meta' -%}
                  {%- render 'product-meta', form: form, block: block, product: product -%}

                {%- when 'description' -%}
                  {%- if product.description != blank -%}
                    <div class="ProductMeta__Description" {{ block.shopify_attributes }}>
                      <div class="Rte">
                        {{- product.description | replace: 'data-section-type', 'data-section-type-placeholder' -}}
                      </div>
                    </div>
                  {%- endif -%}

                {%- when 'share_buttons' -%}
                  <div class="ProductMeta__ShareButtons hidden-pocket" {{ block.shopify_attributes }}>
                    <span class="ProductMeta__ShareTitle Heading Text--subdued u-h7">{{ 'product.form.share' | t }}</span>

                    {%- assign share_url = shop.url | append: product.url -%}
                    {%- assign twitter_text = product.title -%}
                    {%- assign pinterest_description = product.description | strip_html | truncatewords: 15 | url_param_escape -%}
                    {%- assign pinterest_image = product.featured_image | img_url: 'large' | prepend: 'https:' -%}

                    <div class="ProductMeta__ShareList Text--subdued">
                      <a class="ProductMeta__ShareItem" href="https://www.facebook.com/sharer.php?u={{ share_url }}" target="_blank" rel="noopener" aria-label="Facebook">{%- render 'icon' with 'facebook' -%}</a>
                      <a class="ProductMeta__ShareItem" href="https://twitter.com/share?{% if twitter_text != blank %}text={{twitter_text}}&{% endif %}url={{ share_url }}" target="_blank" rel="noopener" aria-label="Twitter">{%- render 'icon' with 'twitter' -%}</a>
                      <a class="ProductMeta__ShareItem" href="https://pinterest.com/pin/create/button/?url={{ share_url }}{% if pinterest_image != blank %}&media={{ pinterest_image }}{% endif %}&description={{ pinterest_description }}" target="_blank" rel="noopener" aria-label="Pinterest">{%- render 'icon' with 'pinterest' -%}</a>
                    </div>
                  </div>

                {%- when 'variant_selector' -%}
                  {%- assign has_ouputted_variant_selector = true -%}
                  {%- render 'product-form', block: block, product: product -%}

                {%- when 'quantity_selector' -%}
                  

                {%- when 'inventory' -%}
                  {%- assign hide_inventory_quantity_by_default = false -%}

                  {%- if product.selected_or_first_available_variant.inventory_management == blank or product.selected_or_first_available_variant.inventory_quantity <= 0 -%}
                    {%- assign hide_inventory_quantity_by_default = true -%}
                  {%- endif -%}

                  {%- if block.settings.inventory_quantity_threshold != 0 and product.selected_or_first_available_variant.inventory_quantity > block.settings.inventory_quantity_threshold -%}
                    {%- assign hide_inventory_quantity_by_default = true -%}
                  {%- endif -%}

                  <p class="ProductForm__Inventory Text--subdued" {% if hide_inventory_quantity_by_default %}style="display: none"{% endif %} {{ block.shopify_attributes }}>
                    {%- if block.settings.inventory_quantity_threshold == 0 -%}
                      {{- 'product.form.inventory_quantity_count' | t: count: product.selected_or_first_available_variant.inventory_quantity -}}
                    {%- else -%}
                      {{- 'product.form.low_inventory_quantity_count' | t: count: product.selected_or_first_available_variant.inventory_quantity -}}
                    {%- endif -%}
                  </p>

                {%- when 'buy_buttons' -%}
                  {%- if block.settings.show_payment_button == false or product.selling_plan_groups.size > 0 -%}
                    {%- assign use_primary_button = true -%}
                  {%- else -%}
                    {%- assign use_primary_button = false -%}
                  {%- endif -%}

                  <div class="ProductForm__Quantity-Buy {% if product.tags contains 'waitlist' %} waitlist{% endif %}" id="ProductForm__Quantity-Buy">
                    {%- if product.tags contains 'QTY_LIMITER' -%}
                      {%- for tag in product.tags -%}
                        {%- if tag contains 'MAX_QTY::' -%}
                          <div class="ProductForm__Quantity-Limiter">
                          Limit {{ tag | remove: 'MAX_QTY::' | times: 1 }}
                          </div>
                          {% break %}
                        {%- endif -%}
                      {%- endfor -%}
                    {%- endif -%}

                    {% if settings.enable_gift and settings.gift_wrap_product.id == product.id %}
                      {% assign hide_quantity_selector = true %}
                      {% assign is_gift_product_in_cart = cart.items | where: 'product_id', product.id %}
                    {% endif %}
                    <div class="ProductForm__QuantitySelector {% if hide_quantity_selector %} hidden{% endif %}" {{ block.shopify_attributes }}>                      
                      <div class="QuantitySelector QuantitySelector--large">
                        {%- assign quantity_minus_one = line_item.quantity | minus: 1 -%}
  
                        <button type="button" class="QuantitySelector__Button Link Link--secondary" data-action="decrease-quantity">{% render 'icon' with 'minus' %}</button>
                        <input type="text" class="QuantitySelector__CurrentQuantity" pattern="[0-9]*" name="quantity" value="1" aria-label="{{ 'product.form.quantity' | t }}">
                        <button type="button" class="QuantitySelector__Button Link Link--secondary" data-action="increase-quantity">{% render 'icon' with 'plus' %}</button>
                      </div>
                      <p class="WarningNote" style="display: none;">
                        {{ settings.sku_limiter_cart_message }}
                      </p>
                    </div>

                    <div class="ProductForm__BuyButtons{% if hide_quantity_selector %} hide-quantity-selector {% endif %}" id="ProductForm__BuyButtons" {{ block.shopify_attributes }}>
                      {%- if block.settings.show_payment_button and product.selected_or_first_available_variant.available == false -%}
                        <style>
                          #shopify-section-{{ section.id }} .shopify-payment-button {
                            display: none;
                          }
                        </style>
                      {%- endif -%}
                      
                      {%- liquid
                        if product.options_with_values[1].values.size > 1
                          assign has_multiple_sizes = true
                        endif
    
                        assign available_sizes = 0
                        for option in product.options_with_values
                          assign downcase_option = option.name | downcase
                          assign variant_option = 'option' | append: forloop.index
                          if downcase_option == "size"
                            for value in option.values
                              assign show_size = false
                              for variant in product.variants
                                if variant[variant_option] == value
                                  if variant.image
                                    assign show_size = true
                                    if variant.available
                                      assign available_sizes = available_sizes | plus: 1
                                    endif
                                    break
                                  endif
                                endif
                              endfor
                            endfor
                          endif
                        endfor

                        assign disabled = false
                        if is_gift_product_in_cart != blank
                        else
                          if product.options.size > 1 and has_multiple_sizes and available_sizes > 1
                            unless product.available
                              assign disabled = true
                            endunless
                          else
                            unless product.selected_or_first_available_variant.available
                              unless product.tags contains 'waitlist'
                                assign disabled = true
                              endunless
                            endunless 
                          endif
                        endif
                      %}
                        
                      <button type="submit" data-use-primary-button="{% if use_primary_button %}true{% else %}false{% endif %}" class="{% if is_gift_product_in_cart != blank %} gift-wrap-in-cart {% endif %}ProductForm__AddToCart Button {% if product.selected_or_first_available_variant.available and use_primary_button %}Button--primary{% else %}Button--secondary{% endif %} Button--full" {% if has_multiple_sizes and available_sizes > 1 or disabled %}disabled="disabled"{% endif %}>
                        {% if is_gift_product_in_cart != blank %}
                          {{ 'product.form.gift_wrap_already_added' | t }}
                        {% else %}
                          {%- if product.options.size > 1 and has_multiple_sizes and available_sizes > 1 -%}
                            {% if product.available %}{{ 'product.form.atc_no_selection' | t }}{% else %}{{- 'product.form.out_of_stock' | t -}}{% endif %}                        
                          {%- else -%}
                            {%- if product.selected_or_first_available_variant.available -%}
                              <span>{% if product.tags contains 'preorder' and product.variants.size == 1 and product.selected_or_first_available_variant.metafields.preorder.availability %}{{ 'product.form.pre_order' | t }}{% else %}{{ 'product.form.add_to_cart' | t }}{% endif %}</span>
    
                              {%- if block.settings.show_price_in_button -%}
                                <span class="Button__SeparatorDot"></span>
                                <span>{{ product.selected_or_first_available_variant.price | money }}</span>
                              {%- endif -%}
                            {%- else -%}
                              {%- if product.tags contains 'waitlist' -%}
                                {{ 'product.form.atc_no_selection' | t }}
                              {%- else -%}
                                {{- 'product.form.out_of_stock' | t -}}
                              {%- endif -%}
                              
                            {%- endif -%}
                          {%- endif -%}
                        {%- endif -%}
                      </button>
               
                      
  
                      {% if product.tags contains 'preorder' and product.variants.size == 1 and product.selected_or_first_available_variant.metafields.preorder.availability %}
                        {% if product.selected_or_first_available_variant.metafields.preorder.availability != blank %}<p class="preorder-estimated-shipping-date">ESTIMATED SHIPPING DATE: {{product.selected_or_first_available_variant.metafields.preorder.estimated_shipping_date}}</p>{% endif %}
                        <input class="preorder-properties-preorder" type="hidden" name="properties[_preorder]" value="true">
                        <input class="preorder-properties-estimate-shipping-date" type="hidden" name="properties[Estimated shipping date]" value="{{product.selected_or_first_available_variant.metafields.preorder.estimated_shipping_date}}">
                      {% endif %}
  
                      {%- if block.settings.show_payment_button and product.template_suffix != 'pre-order' -%}
                        {{ form | payment_button }}
                      {%- endif -%}
                      {% if product.selected_or_first_available_variant.available == false %}
                        {% assign show_bis_message = 'block' %}
                      {% else %}
                        {% assign show_bis_message = 'none' %}
                      {% endif %}
                    
                        {%- if product.metafields.custom.pdp_and_checkout_messaging != blank -%}
                          <p class="pdpCustomNote">{{ product.metafields.custom.pdp_and_checkout_messaging }}</p>
                        {%- endif -%}
                    
                    </div>
                  </div>
                <script type="text/javascript">
        function addToFittingRoom(e, fallback) {
            let selectedVariant;
            let selectedVariantId = e.target.dataset.firstAvailableVariantId;
            const searchParams = new URLSearchParams(window.location.search);
            const searchParamsVariant = searchParams.get("variant");
            if(searchParamsVariant) {
              selectedVariantId = searchParamsVariant
            }
            try {
                selectedVariant = ShopifyAnalytics.meta.product.variants.find(function (v) { return parseInt(v.id) == parseInt(selectedVariantId)});
                _tote("event", "addToCart", 
                      {name: "addToCart",
                       productId: e.target.dataset.productId,
                       productTitle: e.target.dataset.productTitle,
                       productVariant: selectedVariant, 
                       productImage:e.target.dataset.productImage});
            } catch (err) 
                {console.log(err); 
            }
           
        }               
    </script>
                  <button
    id="tote-fitting-room-button"
    type="button"
    name="add"
    onClick="addToFittingRoom(event)"
    data-first-available-variant-id="{{ product.selected_or_first_available_variant.id }}"
    data-product-id="{{ product.id }}"
    data-product-title="{{product.title }}"
    data-product-image="{{product.featured_image | image_url: width: 70, height: 70}}"
    data-product-vendor="{{ product.vendor }}"
    class="Button Button--primary Button--full"
    style="display:none;"
>
      Reserve In-Store
  </button>
                <p id="tote-fitting-room-text" style="font-size:0.95em; text-align:center; display:none;">Not in the Hamptons? Call 631-488-4304 to inquire about this item.</p>
                <script type="text/javascript">
    const toteButton = document.getElementById("tote-fitting-room-button");
    const toteText = document.getElementById("tote-fitting-room-text")
    const configToteObserver = { attributes: true, childList: true, subtree: true };
    const targetNode = toteButton.form.id;
   
    const debounceFn = (func, timeout = 400) => {
        var timer;
        var debouncedVersion = (...args) => {
            clearTimeout(timer);
            timer = setTimeout(() => {
                func(...args);
            }, timeout);
        };
        return debouncedVersion;
    };
    const fetchIsVariantInStock = async (data) => {
        var result = await fetch(
            `https://api.bookwithtote.com/api/widget/variant-check/${data.selected_variant_id}`,
            {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data),
            }
        ).then((x) => x.json());
        if(result.isInStock) {
          if(toteButton.disabled) {
            toteButton.disabled = false;
          }
          if(toteButton.style.display == 'none') {
            toteButton.style.display = 'initial';
            toteText.style.display = 'initial';
          }
        } else if(!result.isInStock) {
          if(!toteButton.disabled) {
            toteButton.disabled = true;
          }
          if(toteButton.style.display !== "none") {
            toteButton.style.display="none";
             toteText.style.display = 'none';
          }
        }
    };
    const debouncedFetchIsVariantInStockVersion = debounceFn(
        fetchIsVariantInStock
    );
    const callback = (mutationList, observer) => {
        if(mutationList.length === 1 && mutationList[0].target.id === "tote-fitting-room-button") {
          return;
        }
      
        let selectedVariantId = null;
        const searchParams = new URLSearchParams(window.location.search);
        const searchParamsVariant = searchParams.get("variant");
        if(searchParamsVariant) {
          selectedVariantId = searchParamsVariant
        }
  
        if(!selectedVariantId) {
          return;
        }
        const data = {
            selected_variant_id:
                selectedVariantId,
            shopify_id: 57860915389,
        };
        
        debouncedFetchIsVariantInStockVersion(data);
        
    };
    const observer = new MutationObserver(callback);
    observer.observe(targetNode, configToteObserver);

     let selectedVariantId = null;
    const searchParams = new URLSearchParams(window.location.search);
    const searchParamsVariant = searchParams.get("variant");
    if(searchParamsVariant) {
      selectedVariantId = searchParamsVariant
    }

    if(selectedVariantId) {
      const data = {
          selected_variant_id:
              selectedVariantId,
          shopify_id: 25056968738,
          originStoreId: 276,
      };
      debouncedFetchIsVariantInStockVersion(data);
    }
</script>     
