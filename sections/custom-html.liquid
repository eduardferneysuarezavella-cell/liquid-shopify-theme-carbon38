{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: calc({{ section.settings.padding_top }}px * 0.75);
    padding-bottom: calc({{ section.settings.padding_bottom }}px  * 0.75);
  }

  .section-custom-html-{{ section.id }} {
    text-align: {{ section.settings.text_alignment }};
  }

  .section-custom-html .rte {
    font-weight: 300;
  }

  .section-custom-html .rte * {
    font-family: var(--font-body-family);
  }

  .section-custom-html .rte h1 {
    font-size: 2.4rem;
    letter-spacing: 0.4rem;
    text-transform: uppercase;
  }

  .custom-html__subheading {
    font-size: 1.2rem;
    font-weight: 400;
    font-family: var(--font-body-family);
    line-height: 1.5;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .custom-html__heading {
    font-size: 5.2rem;
    line-height: 1.2;
    letter-spacing: 0.5rem;
    font-family: var(--font-body-family);
    text-transform: uppercase;
    margin: 1rem 0 3rem;
  }


  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  @media screen and (max-width: 750px) {
    .custom-html__heading {
      font-size: 3.2rem;
    }
  }
{%- endstyle -%}

<section class="color-{{ section.settings.color_scheme }} gradient page-width section-{{ section.id }}-padding" id="section-{{ section.id }}">
  <div class="section-custom-html-{{ section.id }} section-custom-html">
    {%- if section.settings.subheading != blank or section.settings.title != blank -%}
      <header class="">
        {%- if section.settings.subheading != blank -%}
          <h3 class="custom-html__subheading">{{ section.settings.subheading | escape }}</h3>
        {%- endif -%}

        {%- if section.settings.title != blank -%}
          <h2  class="custom-html__heading">{{ section.settings.title | escape }}</h2>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="rte">
      {{ section.settings.html }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Custom HTML",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub-heading",
      "default": "Sub-heading"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Your HTML"
    },
    {
      "type": "html",
      "id": "html",
      "label": "HTML content",
      "default": "<p>Write your own custom HTML content.</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.all.text_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.all.text_alignment.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.all.text_alignment.options__3.label"
        },
      ],
      "default": "center",
      "label": "t:sections.all.text_alignment.label",
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "presets": [
    {
      "category": "Advanced",
      "name": "Custom HTML",
      "settings": {}
    }
  ]
}
{% endschema %}
