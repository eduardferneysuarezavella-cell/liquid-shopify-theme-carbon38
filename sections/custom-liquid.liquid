{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: calc({{ section.settings.padding_top }}px * 0.75);
    padding-bottom: calc({{ section.settings.padding_bottom }}px  * 0.75);
    padding-left: 24px;
    padding-right: 24px;
  }

  .section-custom-liquid-{{ section.id }} {
    text-align: {{ section.settings.text_alignment }};
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      padding-left: 80px;
      padding-right: 80px;
    }
  }

  .custom-liquid__subheading {
    font-size: 1.2rem;
    font-weight: 400;
    font-family: var(--font-body-family);
    line-height: 1.5;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .custom-liquid__heading {
    font-size: 5.2rem;
    line-height: 1.2;
    letter-spacing: 0.5rem;
    font-family: var(--font-body-family);
    text-transform: uppercase;
    margin: 1rem 0 3rem;
  }

  @media screen and (max-width: 750px) {
    .custom-liquid__heading {
      font-size: 3.2rem;
    }
  }

  .section-{{ section.id }}-padding h5 {
    font-size: 14px;
    font-weight: 400;
    line-height: 18px;
    letter-spacing: 1.44px;
    text-transform: uppercase;
  }
  .section-{{ section.id }}-padding h2 {
    font-size: 54px;
    line-height: 65px;
  }
  @media (max-width: 749px) {
    .section-{{ section.id }}-padding h2 {
      font-size: 37px;
      line-height: 45px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding section-custom-liquid-{{ section.id }}">
  {% if section.settings.subheading != blank %}
    <h3 class="custom-liquid__subheading">{{ section.settings.subheading }}</h3>
  {% endif %}

  {% if section.settings.heading != blank %}
    <h2 class="custom-liquid__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="rte">
    {{ section.settings.custom_liquid }}
  </div>
</div>

{% schema %}
{
  "name": "t:sections.custom-liquid.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Sub-heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "liquid",
      "id": "custom_liquid",
      "label": "t:sections.custom-liquid.settings.custom_liquid.label",
      "info": "t:sections.custom-liquid.settings.custom_liquid.info"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "options": [
        {
          "value": "left",
          "label": "t:sections.all.text_alignment.options__1.label"
        },
        {
          "value": "center",
          "label": "t:sections.all.text_alignment.options__2.label"
        },
        {
          "value": "right",
          "label": "t:sections.all.text_alignment.options__3.label"
        },
      ],
      "default": "center",
      "label": "t:sections.all.text_alignment.label",
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "t:sections.custom-liquid.presets.name"
    }
  ]
}
{% endschema %}
