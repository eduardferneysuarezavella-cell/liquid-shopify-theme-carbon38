        {
          "type": "color",
          "id": "section_background_color",
          "label": "Widget Background Color",
          "default": "#eee"
        },
        {
          "type": "color",
          "id": "label_color",
          "label": "Radio Buttons Background Color",
          "default": "#fff"
        },
        {
