        "label": "Title 1"
      },
      {
        "type": "richtext",
        "id": "custom_content_1",
        "label": "Custom Content 1"
      },
      {
        "type": "liquid",
        "id": "liquid_object_1",
        "label": "Liquid Object 1"
      },
      {
        "type": "header",
        "content": "Accordion Item 2"
      },
      {
        "type": "text",
        "id": "title_2",
        "label": "Title 2"
      },
      {
        "type": "richtext",
        "id": "custom_content_2",
        "label": "Custom Content 2"
      },
      {
        "type": "liquid",
        "id": "liquid_object_2",
        "label": "Liquid Object 2"
      },
      {
        "type": "header",
        "content": "Accordion Item 3"
      },
      {
        "type": "text",
        "id": "title_3",
        "label": "Title 3"
      },
      {
        "type": "richtext",
        "id": "custom_content_3",
        "label": "Custom Content 3"
      },
      {
        "type": "liquid",
        "id": "liquid_object_3",
        "label": "Liquid Object 3"
      }
      ]
    },
    {
      "type": "description",
